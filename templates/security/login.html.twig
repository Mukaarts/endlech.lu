{% extends 'base.html.twig' %}

{% block title %}Login - Endlech.lu{% endblock %}

{% block body %}
<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">

            {# Titel #}
            <div class="text-center mb-8">
                <h1 class="text-2xl font-bold text-gray-900 mb-2">Anmelden</h1>
                <p class="text-gray-500 text-sm">Willkommen zurück bei Endlech.lu</p>
            </div>

            {% include 'partials/_flash_messages.html.twig' %}

            {% if error %}
                <div class="bg-red-50 border-l-4 border-red-400 text-red-800 px-4 py-3 rounded-r-lg mb-4" role="alert">
                    <p class="text-sm font-medium">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                </div>
            {% endif %}

            <form method="post" class="space-y-5">

                {# E-Mail #}
                <div>
                    <label for="inputEmail" class="block text-sm font-semibold text-gray-700 mb-1">E-Mail-Adresse</label>
                    <input type="email" id="inputEmail" name="_username" value="{{ last_username }}" required autofocus autocomplete="email" placeholder="deine@email.lu" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition">
                </div>

                {# Passwort #}
                <div>
                    <label for="inputPassword" class="block text-sm font-semibold text-gray-700 mb-1">Passwort</label>
                    <input type="password" id="inputPassword" name="_password" required autocomplete="current-password" placeholder="Dein Passwort" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition">
                </div>

                {# Angemeldet bleiben #}
                <div class="flex items-center">
                    <input type="checkbox" id="rememberMe" name="_remember_me" class="rounded text-purple-600 focus:ring-purple-500 border-gray-300">
                    <label for="rememberMe" class="ml-2 text-sm text-gray-600">Angemeldet bleiben</label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Absenden #}
                <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-lg shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    Anmelden
                </button>
            </form>

            {# Link zu Registrierung #}
            <p class="text-center text-sm text-gray-500 mt-6">
                Noch kein Konto?
                <a href="{{ path('app_register') }}" class="text-purple-600 font-semibold hover:text-purple-800 transition">Registrieren</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
