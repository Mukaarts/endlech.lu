{% extends 'base.html.twig' %}

{% block title %}{{ 'legal.title'|trans }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12 max-w-2xl">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">{{ 'legal.heading'|trans }}</h1>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">{{ 'legal.info_title'|trans }}</h2>
        <p class="text-gray-700 leading-relaxed">
            {{ 'legal.info_text'|trans|nl2br }}
        </p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">{{ 'legal.contact_title'|trans }}</h2>
        <p class="text-gray-700 leading-relaxed">
            {{ 'legal.contact_email_label'|trans }} <a href="mailto:info@endlech.lu" class="text-cyan-600 hover:underline">info@endlech.lu</a>
        </p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">{{ 'legal.disclaimer_title'|trans }}</h2>
        <h3 class="text-base font-semibold text-gray-700 mb-2">{{ 'legal.content_title'|trans }}</h3>
        <p class="text-gray-600 leading-relaxed mb-4">
            {{ 'legal.content_text'|trans }}
        </p>
        <h3 class="text-base font-semibold text-gray-700 mb-2">{{ 'legal.links_title'|trans }}</h3>
        <p class="text-gray-600 leading-relaxed">
            {{ 'legal.links_text'|trans }}
        </p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-3">{{ 'legal.privacy_title'|trans }}</h2>
        <p class="text-gray-600 leading-relaxed">
            {{ 'legal.privacy_text'|trans }}
        </p>
    </section>
</div>
{% endblock %}
