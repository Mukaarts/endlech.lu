{% extends 'base.html.twig' %}

{% block title %}{{ 'criteria.title'|trans }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-12 max-w-3xl">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">{{ 'criteria.heading'|trans }}</h1>
    <p class="text-gray-600 mb-10 text-lg">
        {{ 'criteria.intro'|trans }}
    </p>

    <div class="space-y-6">

        {# Eingang #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">🚪</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.entrance_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.entrance_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# Parkplatz #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">🅿️</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.parking_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.parking_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# WC #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">🚻</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.toilet_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.toilet_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# Rollstuhl im Innenbereich #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">♿</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.interior_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.interior_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# Personal #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">🙋</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.staff_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.staff_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

        {# Speisekarte #}
        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="text-3xl">📋</div>
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ 'criteria.menu_title'|trans }}</h2>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        {{ 'criteria.menu_text'|trans }}
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-12 bg-cyan-50 border border-cyan-200 rounded-xl p-6">
        <p class="text-cyan-800 text-sm leading-relaxed">
            <strong>{{ 'criteria.note_label'|trans }}</strong> {{ 'criteria.note_text'|trans }}
        </p>
    </div>
</div>
{% endblock %}
