{% extends 'admin/base.html.twig' %}

{% block admin_title %}{{ 'admin.nav.suggestions'|trans }}{% endblock %}

{% block admin_body %}
<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-800">{{ 'admin.suggestion.title'|trans }}</h2>
    <span class="bg-cyan-100 text-cyan-800 text-xs font-bold px-3 py-1 rounded-full">
        {{ 'admin.suggestion.open_count'|trans({'%count%': pending|length}) }}
    </span>
</div>

{# --- Offene Vorschläge --- #}
<section class="mb-10">
    <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.suggestion.pending'|trans({'%count%': pending|length}) }}</h3>

    {% if pending is empty %}
        <div class="bg-white rounded-xl border border-gray-200 p-8 text-center text-gray-400">
            {{ 'admin.suggestion.no_pending'|trans }}
        </div>
    {% else %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ 'admin.suggestion.table_restaurant'|trans }}</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">{{ 'admin.suggestion.table_from'|trans }}</th>
                        <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">{{ 'admin.suggestion.table_date'|trans }}</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for s in pending %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <span class="mr-1">{{ s.emoji }}</span>
                                <span class="font-semibold text-gray-800">{{ s.name }}</span>
                                <span class="text-gray-500 ml-1">· {{ s.city }}</span>
                            </td>
                            <td class="px-4 py-3 text-gray-500 hidden md:table-cell">
                                {{ s.suggestedBy ? s.suggestedBy.name : '–' }}
                            </td>
                            <td class="px-4 py-3 text-gray-400 hidden md:table-cell">
                                {{ s.createdAt|date('d.m.Y') }}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a href="{{ path('admin_suggestion_show', {id: s.id}) }}"
                                   class="text-purple-600 hover:text-purple-800 font-semibold text-xs transition">
                                    {{ 'admin.suggestion.review'|trans }}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</section>

{# --- Genehmigte Vorschläge --- #}
<section class="mb-10">
    <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.suggestion.approved_title'|trans({'%count%': approved|length}) }}</h3>

    {% if approved is empty %}
        <p class="text-gray-400 text-sm">{{ 'admin.suggestion.no_approved'|trans }}</p>
    {% else %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="w-full text-sm">
                <tbody class="divide-y divide-gray-100">
                    {% for s in approved %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <span class="mr-1">{{ s.emoji }}</span>
                                <span class="font-medium text-gray-700">{{ s.name }}</span>
                                <span class="text-gray-400 ml-1">· {{ s.city }}</span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-0.5 rounded-full">✓ {{ 'admin.suggestion.approved_badge'|trans }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</section>

{# --- Abgelehnte Vorschläge --- #}
<section>
    <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.suggestion.rejected_title'|trans({'%count%': rejected|length}) }}</h3>

    {% if rejected is empty %}
        <p class="text-gray-400 text-sm">{{ 'admin.suggestion.no_rejected'|trans }}</p>
    {% else %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <table class="w-full text-sm">
                <tbody class="divide-y divide-gray-100">
                    {% for s in rejected %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3">
                                <span class="mr-1">{{ s.emoji }}</span>
                                <span class="font-medium text-gray-500">{{ s.name }}</span>
                                <span class="text-gray-400 ml-1">· {{ s.city }}</span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <span class="bg-red-100 text-red-600 text-xs font-bold px-2 py-0.5 rounded-full">✕ {{ 'admin.suggestion.rejected_badge'|trans }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</section>

{% endblock %}
