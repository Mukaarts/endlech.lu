{% extends 'admin/base.html.twig' %}

{% block admin_title %}{{ 'admin.restaurant.new_title'|trans }}{% endblock %}

{% block admin_body %}
<div class="mb-6">
    <a href="{{ path('admin_restaurant_index') }}" class="text-purple-600 hover:text-purple-800 font-semibold text-sm transition">
        ← {{ 'admin.restaurant.back_to_list'|trans }}
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-3xl">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">{{ 'admin.restaurant.new_title'|trans }}</h2>

    {% include 'admin/restaurant/_form.html.twig' with {
        form: form,
        button_label: 'admin.restaurant.create_button'|trans
    } %}
</div>
{% endblock %}
