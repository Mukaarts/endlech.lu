{% extends 'admin/base.html.twig' %}

{% block admin_title %}Restaurants{% endblock %}

{% block admin_body %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Restaurants verwalten</h2>
    <a href="{{ path('admin_restaurant_new') }}"
       class="bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
        + Neues Restaurant
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-4 py-3 font-semibold text-gray-600">ID</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Name</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Stadt</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Küche</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Bewertung</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Status</th>
                    <th class="px-4 py-3 font-semibold text-gray-600">Barrierefreiheit</th>
                    <th class="px-4 py-3 font-semibold text-gray-600 text-right">Aktionen</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for restaurant in restaurants %}
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-4 py-3 text-gray-400">{{ restaurant.id }}</td>
                    <td class="px-4 py-3 font-medium text-gray-900">
                        {{ restaurant.emoji }} {{ restaurant.name }}
                    </td>
                    <td class="px-4 py-3 text-gray-600">{{ restaurant.city }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ restaurant.cuisine }}</td>
                    <td class="px-4 py-3">
                        {% if restaurant.rating is not null %}
                            <span class="bg-cyan-50 text-cyan-700 px-2 py-0.5 rounded text-xs font-bold border border-cyan-100">{{ restaurant.rating }}</span>
                        {% else %}
                            <span class="text-gray-400">—</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3">
                        {% if restaurant.isOpen %}
                            <span class="bg-green-50 text-green-700 px-2 py-0.5 rounded text-xs font-bold border border-green-100">Geöffnet</span>
                        {% else %}
                            <span class="bg-red-50 text-red-700 px-2 py-0.5 rounded text-xs font-bold border border-red-100">Geschlossen</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex gap-1">
                            {% if restaurant.isWheelchairAccessible %}<span title="Rollstuhlgerecht">♿</span>{% endif %}
                            {% if restaurant.hasAccessibleToilet %}<span title="Barrierefreies WC">🚻</span>{% endif %}
                            {% if restaurant.allowsAssistanceDogs %}<span title="Assistenzhund">🐕</span>{% endif %}
                            {% if restaurant.hasBrightLighting %}<span title="Helle Beleuchtung">💡</span>{% endif %}
                        </div>
                    </td>
                    <td class="px-4 py-3 text-right">
                        <div class="flex justify-end gap-2">
                            <a href="{{ path('admin_restaurant_edit', {id: restaurant.id}) }}"
                               class="text-purple-600 hover:text-purple-800 font-semibold text-xs transition">
                                Bearbeiten
                            </a>
                            <form method="post" action="{{ path('admin_restaurant_delete', {id: restaurant.id}) }}"
                                  onsubmit="return confirm('Restaurant \u00ab{{ restaurant.name|e('js') }}\u00bb wirklich löschen?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-restaurant-' ~ restaurant.id) }}">
                                <button type="submit" class="text-red-600 hover:text-red-800 font-semibold text-xs transition">
                                    Löschen
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="px-4 py-8 text-center text-gray-400">
                        Noch keine Restaurants vorhanden.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<p class="text-sm text-gray-400 mt-4">{{ restaurants|length }} Restaurant{{ restaurants|length != 1 ? 's' : '' }} insgesamt</p>
{% endblock %}
