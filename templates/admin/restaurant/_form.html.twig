{# Gemeinsames Formular-Partial für Restaurant erstellen/bearbeiten #}

{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

    {# --- Grunddaten --- #}
    <fieldset class="space-y-5">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.basic_data'|trans }}</legend>

        {# Name #}
        <div>
            {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
            {{ form_errors(form.name, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
        </div>

        {# Stadt #}
        <div>
            {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.city, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
            {{ form_errors(form.city, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
        </div>

        {# Küchen-Typen (Tom Select) #}
        <div>
            {{ form_label(form.cuisines, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.cuisines) }}
            {{ form_errors(form.cuisines, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
        </div>

        {# Emoji & Bewertung (2-Spalten) #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.emoji, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.emoji, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.emoji, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.rating, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.rating, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.rating, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
        </div>
    </fieldset>

    {# --- Status --- #}
    <fieldset>
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.status'|trans }}</legend>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.isVerified, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-cyan-700">✓ {{ 'admin.form.is_verified'|trans }}</span>
        </label>
    </fieldset>

    {# --- Öffnungszeiten --- #}
    <fieldset>
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.opening_hours'|trans }}</legend>
        <p class="text-xs text-gray-400 mb-3">{{ 'admin.form.opening_hours_hint'|trans }}</p>

        <div data-controller="opening-hours-form" class="space-y-2">
            {% set dayNames = {1: 'opening_hours.day_1', 2: 'opening_hours.day_2', 3: 'opening_hours.day_3', 4: 'opening_hours.day_4', 5: 'opening_hours.day_5', 6: 'opening_hours.day_6', 7: 'opening_hours.day_7'} %}
            {% for oh in form.openingHours %}
                {{ form_widget(oh.dayOfWeek) }}
                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200" data-opening-hours-form-target="row">
                    <span class="text-sm font-semibold text-gray-700 w-24 shrink-0">{{ dayNames[oh.vars.data.dayOfWeek]|trans }}</span>
                    <div class="flex items-center gap-2 flex-1">
                        {{ form_widget(oh.openTime, {'attr': {'class': 'bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-purple-500 focus:outline-none w-32'}}) }}
                        <span class="text-gray-400 text-sm">–</span>
                        {{ form_widget(oh.closeTime, {'attr': {'class': 'bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-purple-500 focus:outline-none w-32'}}) }}
                    </div>
                    <label class="flex items-center gap-2 cursor-pointer group shrink-0">
                        {{ form_widget(oh.isClosed, {'attr': {'class': 'rounded text-red-500 focus:ring-red-400 border-gray-300', 'data-action': 'opening-hours-form#toggle'}}) }}
                        <span class="text-xs text-gray-500 group-hover:text-red-600">{{ 'opening_hours.closed'|trans }}</span>
                    </label>
                </div>
            {% endfor %}
        </div>
    </fieldset>

    {# --- Barrierefreiheit --- #}
    <fieldset class="space-y-3">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.accessibility'|trans }}</legend>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.isWheelchairAccessible, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">♿ {{ 'admin.form.wheelchair'|trans }}</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.hasAccessibleToilet, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🚻 {{ 'admin.form.toilet'|trans }}</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.allowsAssistanceDogs, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🐕 {{ 'admin.form.dogs'|trans }}</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.hasBrightLighting, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">💡 {{ 'admin.form.lighting'|trans }}</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.hasChangingTable, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🍼 {{ 'admin.form.changing_table'|trans }}</span>
        </label>

        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.hasDisabledParking, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🅿️ {{ 'admin.form.disabled_parking'|trans }}</span>
        </label>
    </fieldset>

    {# --- Zahlungsmethoden --- #}
    <fieldset class="space-y-3">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.payment'|trans }}</legend>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.acceptsCash, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">💵 {{ 'admin.form.cash'|trans }}</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.acceptsCard, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">💳 {{ 'admin.form.card'|trans }}</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.acceptsPayconiq, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">📱 {{ 'admin.form.payconiq'|trans }}</span>
        </label>
    </fieldset>

    {# --- Ernährungsoptionen --- #}
    <fieldset class="space-y-3">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.dietary'|trans }}</legend>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.isVegan, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🌱 {{ 'admin.form.vegan'|trans }}</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.isVegetarian, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">🥗 {{ 'admin.form.vegetarian'|trans }}</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer group">
            {{ form_widget(form.isHalal, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
            <span class="text-sm text-gray-600 group-hover:text-purple-700">☪️ {{ 'admin.form.halal'|trans }}</span>
        </label>
    </fieldset>

    {# --- Gesprochene Sprachen --- #}
    <fieldset class="space-y-3">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.spoken_languages'|trans }}</legend>
        {% for child in form.spokenLanguages %}
            <label class="flex items-center gap-3 cursor-pointer group">
                {{ form_widget(child, {'attr': {'class': 'rounded text-purple-600 focus:ring-purple-500 border-gray-300'}}) }}
                <span class="text-sm text-gray-600 group-hover:text-purple-700">{{ child.vars.label }}</span>
            </label>
        {% endfor %}
    </fieldset>

    {# --- Kontaktdaten & Social Media --- #}
    <fieldset class="space-y-5">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.contact'|trans }}</legend>

        {# Telefon & E-Mail (2-Spalten) #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.phone, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.phone, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.email, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
        </div>

        {# Webseite (volle Breite) #}
        <div>
            {{ form_label(form.website, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.website, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
            {{ form_errors(form.website, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
        </div>

        {# Instagram / Facebook / TikTok (3-Spalten) #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                {{ form_label(form.instagramUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.instagramUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.instagramUrl, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.facebookUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.facebookUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.facebookUrl, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.tiktokUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.tiktokUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.tiktokUrl, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
        </div>
    </fieldset>

    {# --- Standort & Nahverkehr --- #}
    <fieldset class="space-y-5">
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.location'|trans }}</legend>
        <p class="text-xs text-gray-400 mb-3">{{ 'admin.form.location_hint'|trans }}</p>

        {# Latitude & Longitude (2-Spalten) #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.latitude, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.latitude, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.latitude, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.longitude, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                {{ form_widget(form.longitude, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                {{ form_errors(form.longitude, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
            </div>
        </div>

        {# Nahverkehrs-Hinweis (volle Breite) #}
        <div>
            {{ form_label(form.nearbyStopsNote, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
            {{ form_widget(form.nearbyStopsNote, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
            {{ form_errors(form.nearbyStopsNote, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
        </div>
    </fieldset>

    {# --- Bestelloptionen (dynamische Collection) --- #}
    <fieldset>
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.ordering'|trans }}</legend>
        <p class="text-xs text-gray-400 mb-3">{{ 'admin.form.ordering_hint'|trans }}</p>

        <div data-controller="collection-form"
             data-collection-form-prototype-value="{{ form_widget(form.orderingOptions.vars.prototype)|e('html_attr') }}">

            <div data-collection-form-target="entries" class="space-y-3">
                {% for option in form.orderingOptions %}
                    <div class="flex items-center gap-2" data-collection-form-target="entry">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 flex-1">
                            {{ form_widget(option.platform, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                            {{ form_widget(option.url, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                        </div>
                        <button type="button" data-action="collection-form#removeEntry"
                                class="text-red-500 hover:text-red-700 text-sm font-bold px-2 py-1 shrink-0 transition">
                            ✕
                        </button>
                    </div>
                    {{ form_errors(option.platform, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                    {{ form_errors(option.url, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                {% endfor %}
            </div>

            <button type="button" data-action="collection-form#addEntry"
                    class="mt-3 text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                {{ 'admin.form.add_ordering'|trans }}
            </button>
        </div>
    </fieldset>

    {# --- Hinweise zur Barrierefreiheit (dynamische Collection) --- #}
    <fieldset>
        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'admin.form.accessibility_notes'|trans }}</legend>
        <p class="text-xs text-gray-400 mb-3">{{ 'admin.form.notes_hint'|trans }}</p>

        <div data-controller="collection-form"
             data-collection-form-prototype-value="{{ form_widget(form.accessibilityNotes.vars.prototype, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}})|e('html_attr') }}">

            <div data-collection-form-target="entries" class="space-y-3">
                {% for note in form.accessibilityNotes %}
                    <div class="flex items-center gap-2" data-collection-form-target="entry">
                        {{ form_widget(note, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                        <button type="button" data-action="collection-form#removeEntry"
                                class="text-red-500 hover:text-red-700 text-sm font-bold px-2 py-1 shrink-0 transition">
                            ✕
                        </button>
                    </div>
                    {{ form_errors(note, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                {% endfor %}
            </div>

            <button type="button" data-action="collection-form#addEntry"
                    class="mt-3 text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                {{ 'admin.form.add_note'|trans }}
            </button>
        </div>
    </fieldset>

    {# Submit #}
    <div class="pt-4 border-t border-gray-200 flex items-center gap-4">
        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-bold px-8 py-3 rounded-lg shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
            {{ button_label }}
        </button>
        <a href="{{ path('admin_restaurant_index') }}" class="text-sm font-semibold text-gray-500 hover:text-gray-700 transition">
            {{ 'admin.form.cancel'|trans }}
        </a>
    </div>

{{ form_end(form) }}
