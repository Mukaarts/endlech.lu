{% extends 'admin/base.html.twig' %}

{% block admin_title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% block admin_body %}
<h2 class="text-2xl font-bold text-gray-800 mb-6">{{ 'admin.dashboard.title'|trans }}</h2>

{# Hauptstatistiken #}
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    {# Restaurant-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-cyan-50 text-cyan-600 p-3 rounded-lg text-2xl">🍽️</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.restaurants'|trans }}</p>
                <p class="text-3xl font-bold text-gray-900">{{ restaurantCount }}</p>
            </div>
        </div>
        <div class="mt-4 pt-4 border-t border-gray-100">
            <a href="{{ path('admin_restaurant_index') }}" class="text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                {{ 'admin.dashboard.view_all'|trans }}
            </a>
        </div>
    </div>

    {# Verifizierte Lokale-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-cyan-100 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-cyan-50 text-cyan-600 p-3 rounded-lg text-2xl">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.verified'|trans }}</p>
                <p class="text-3xl font-bold text-cyan-700">{{ verifiedCount }}</p>
            </div>
        </div>
    </div>

    {# Vorschläge-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 {{ pendingSuggestionCount > 0 ? 'border-amber-300' : '' }}">
        <div class="flex items-center gap-4">
            <div class="bg-amber-50 text-amber-600 p-3 rounded-lg text-2xl">💡</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.pending_suggestions'|trans }}</p>
                <p class="text-3xl font-bold {{ pendingSuggestionCount > 0 ? 'text-amber-600' : 'text-gray-900' }}">{{ pendingSuggestionCount }}</p>
            </div>
        </div>
        <div class="mt-4 pt-4 border-t border-gray-100">
            <a href="{{ path('admin_suggestion_index') }}" class="text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                {{ 'admin.dashboard.review_suggestions'|trans }}
            </a>
        </div>
    </div>

</div>

{# Zusätzliche Statistiken #}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-6">

    {# Benutzer #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-purple-50 text-purple-600 p-3 rounded-lg text-2xl">👤</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.users'|trans }}</p>
                <p class="text-3xl font-bold text-gray-900">{{ userCount }}</p>
            </div>
        </div>
    </div>

    {# Restaurants diesen Monat #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-green-50 text-green-600 p-3 rounded-lg text-2xl">📅</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.restaurants_this_month'|trans }}</p>
                <p class="text-3xl font-bold text-gray-900">{{ restaurantsThisMonth }}</p>
            </div>
        </div>
    </div>

    {# Benutzer diesen Monat #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-indigo-50 text-indigo-600 p-3 rounded-lg text-2xl">📅</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.users_this_month'|trans }}</p>
                <p class="text-3xl font-bold text-gray-900">{{ usersThisMonth }}</p>
            </div>
        </div>
    </div>

    {# Fotos #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-pink-50 text-pink-600 p-3 rounded-lg text-2xl">🖼️</div>
            <div>
                <p class="text-sm text-gray-500">{{ 'admin.dashboard.photos'|trans }}</p>
                <p class="text-3xl font-bold text-gray-900">{{ imageCount }}</p>
            </div>
        </div>
    </div>

</div>

{# Schnellaktionen #}
<div class="mt-8">
    <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.dashboard.quick_actions'|trans }}</h3>
    <div class="flex flex-wrap gap-3">
        <a href="{{ path('admin_restaurant_new') }}"
           class="bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
            {{ 'admin.dashboard.new_restaurant'|trans }}
        </a>
        <a href="{{ path('admin_restaurant_index') }}"
           class="bg-white hover:bg-gray-50 text-gray-700 font-bold px-5 py-2.5 rounded-full border border-gray-300 shadow-sm hover:shadow-md transition">
            {{ 'admin.dashboard.manage_restaurants'|trans }}
        </a>
        {% if pendingSuggestionCount > 0 %}
            <a href="{{ path('admin_suggestion_index') }}"
               class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                💡 {{ pendingSuggestionCount == 1 ? 'admin.dashboard.review_count_one'|trans({'%count%': pendingSuggestionCount}) : 'admin.dashboard.review_count_other'|trans({'%count%': pendingSuggestionCount}) }}
            </a>
        {% endif %}
    </div>
</div>

{# Tabellen: Zuletzt hinzugefügt #}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-8">

    {# Zuletzt hinzugefügte Restaurants #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.dashboard.recent_restaurants'|trans }}</h3>
        {% if recentRestaurants|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 text-left text-gray-500">
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_name'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_city'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_date'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_status'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for restaurant in recentRestaurants %}
                            <tr class="border-b border-gray-100 last:border-0">
                                <td class="py-3">
                                    <span class="mr-1">{{ restaurant.emoji }}</span>
                                    <span class="font-medium text-gray-900">{{ restaurant.name }}</span>
                                </td>
                                <td class="py-3 text-gray-600">{{ restaurant.city }}</td>
                                <td class="py-3 text-gray-600">{{ restaurant.createdAt|date('d.m.Y') }}</td>
                                <td class="py-3">
                                    {% include 'partials/_verified_badge.html.twig' with { restaurant: restaurant, size: 'sm' } only %}
                                </td>
                                <td class="py-3">
                                    <a href="{{ path('admin_restaurant_edit', { id: restaurant.id }) }}"
                                       class="text-purple-600 hover:text-purple-800 font-medium transition">
                                        {{ 'admin.dashboard.edit'|trans }}
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-gray-500 text-sm">{{ 'admin.dashboard.no_recent_restaurants'|trans }}</p>
        {% endif %}
    </div>

    {# Zuletzt registrierte Benutzer #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-bold text-gray-700 mb-4">{{ 'admin.dashboard.recent_users'|trans }}</h3>
        {% if recentUsers|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 text-left text-gray-500">
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_name'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_email'|trans }}</th>
                            <th class="pb-3 font-medium">{{ 'admin.dashboard.table_registered'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in recentUsers %}
                            <tr class="border-b border-gray-100 last:border-0">
                                <td class="py-3 font-medium text-gray-900">{{ user.name }}</td>
                                <td class="py-3 text-gray-600">{{ user.email }}</td>
                                <td class="py-3 text-gray-600">{{ user.createdAt|date('d.m.Y') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-gray-500 text-sm">{{ 'admin.dashboard.no_recent_users'|trans }}</p>
        {% endif %}
    </div>

</div>
{% endblock %}
