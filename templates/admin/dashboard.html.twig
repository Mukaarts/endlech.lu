{% extends 'admin/base.html.twig' %}

{% block admin_title %}Dashboard{% endblock %}

{% block admin_body %}
<h2 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h2>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    {# Restaurant-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-cyan-50 text-cyan-600 p-3 rounded-lg text-2xl">🍽️</div>
            <div>
                <p class="text-sm text-gray-500">Restaurants</p>
                <p class="text-3xl font-bold text-gray-900">{{ restaurantCount }}</p>
            </div>
        </div>
        <div class="mt-4 pt-4 border-t border-gray-100">
            <a href="{{ path('admin_restaurant_index') }}" class="text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                Alle anzeigen →
            </a>
        </div>
    </div>

    {# Verifizierte Lokale-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-cyan-100 p-6">
        <div class="flex items-center gap-4">
            <div class="bg-cyan-50 text-cyan-600 p-3 rounded-lg text-2xl">
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <p class="text-sm text-gray-500">Verifizierte Lokale</p>
                <p class="text-3xl font-bold text-cyan-700">{{ verifiedCount }}</p>
            </div>
        </div>
    </div>

    {# Vorschläge-Karte #}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 {{ pendingSuggestionCount > 0 ? 'border-amber-300' : '' }}">
        <div class="flex items-center gap-4">
            <div class="bg-amber-50 text-amber-600 p-3 rounded-lg text-2xl">💡</div>
            <div>
                <p class="text-sm text-gray-500">Offene Vorschläge</p>
                <p class="text-3xl font-bold {{ pendingSuggestionCount > 0 ? 'text-amber-600' : 'text-gray-900' }}">{{ pendingSuggestionCount }}</p>
            </div>
        </div>
        <div class="mt-4 pt-4 border-t border-gray-100">
            <a href="{{ path('admin_suggestion_index') }}" class="text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                Vorschläge prüfen →
            </a>
        </div>
    </div>

</div>

{# Schnellaktionen #}
<div class="mt-8">
    <h3 class="text-lg font-bold text-gray-700 mb-4">Schnellaktionen</h3>
    <div class="flex flex-wrap gap-3">
        <a href="{{ path('admin_restaurant_new') }}"
           class="bg-purple-600 hover:bg-purple-700 text-white font-bold px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
            + Neues Restaurant
        </a>
        <a href="{{ path('admin_restaurant_index') }}"
           class="bg-white hover:bg-gray-50 text-gray-700 font-bold px-5 py-2.5 rounded-full border border-gray-300 shadow-sm hover:shadow-md transition">
            Restaurants verwalten
        </a>
        {% if pendingSuggestionCount > 0 %}
            <a href="{{ path('admin_suggestion_index') }}"
               class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                💡 {{ pendingSuggestionCount }} Vorschlag{{ pendingSuggestionCount != 1 ? 'schläge' : '' }} prüfen
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}
