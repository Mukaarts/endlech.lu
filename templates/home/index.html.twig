{% extends 'base.html.twig' %}

{% block title %}Endlech.lu - Barrierefreie Restaurants in Luxemburg{% endblock %}

{% block body %}

    {# === HERO SECTION === #}
    <section class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-20 shadow-md">
        <div class="container mx-auto px-4 text-center">
            <span class="inline-block bg-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
                {{ totalCount }} Restaurants in Luxemburg
            </span>
            <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
                Barrierefreie Restaurants<br class="hidden md:block"> in Luxemburg finden
            </h1>
            <p class="text-cyan-100 text-lg md:text-xl max-w-2xl mx-auto mb-8">
                Endlech.lu hilft dir, Restaurants zu finden, die wirklich für alle zugänglich sind.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="{{ path('app_restaurant_index') }}" class="bg-white text-purple-700 font-bold px-8 py-3 rounded-full shadow-lg hover:shadow-xl transition transform hover:-translate-y-0.5">
                    Restaurants entdecken
                </a>
                <a href="{{ path('app_register') }}" class="border-2 border-white text-white font-bold px-8 py-3 rounded-full hover:bg-white/10 transition">
                    Mitmachen
                </a>
            </div>
        </div>
    </section>

    {# === SO FUNKTIONIERT'S === #}
    <section class="bg-white py-16">
        <div class="container mx-auto px-4">
            <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-12">So funktioniert's</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">

                {# Schritt 1: Suchen #}
                <div class="text-center">
                    <div class="w-16 h-16 bg-cyan-50 text-cyan-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-800 mb-2">Suchen</h3>
                    <p class="text-gray-500 text-sm">Finde barrierefreie Restaurants in deiner Nähe.</p>
                </div>

                {# Schritt 2: Informieren #}
                <div class="text-center">
                    <div class="w-16 h-16 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-800 mb-2">Informieren</h3>
                    <p class="text-gray-500 text-sm">Sieh dir Barrierefreiheits-Details und Bewertungen an.</p>
                </div>

                {# Schritt 3: Bewerten #}
                <div class="text-center">
                    <div class="w-16 h-16 bg-cyan-50 text-cyan-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-lg text-gray-800 mb-2">Bewerten</h3>
                    <p class="text-gray-500 text-sm">Teile deine Erfahrungen und hilf anderen.</p>
                </div>

            </div>
        </div>
    </section>

    {# === TOP BEWERTETE RESTAURANTS === #}
    <section class="bg-gray-50 py-16">
        <div class="container mx-auto px-4">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-2">Top bewertete Restaurants</h2>
                <p class="text-gray-500">Die bestbewerteten barrierefreien Restaurants auf unserer Plattform.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
                {% for restaurant in restaurants %}
                    <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition group flex flex-col">
                        <div class="h-36 bg-gray-100 relative flex items-center justify-center text-gray-300 text-5xl">
                            {{ restaurant.emoji }}
                            {% if restaurant.isOpen %}
                                <span class="absolute top-3 right-3 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm">Geöffnet</span>
                            {% else %}
                                <span class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm">Geschlossen</span>
                            {% endif %}
                        </div>
                        <div class="p-5 flex-grow">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="text-lg font-bold text-gray-900 group-hover:text-purple-700 transition">{{ restaurant.name }}</h3>
                                    <p class="text-sm text-gray-500">{{ restaurant.city }} &bull; {{ restaurant.cuisine }}</p>
                                </div>
                                {% if restaurant.rating is not null %}
                                    <div class="bg-cyan-50 text-cyan-700 px-2 py-1 rounded text-xs font-bold border border-cyan-100 shrink-0">{{ restaurant.rating }}</div>
                                {% endif %}
                            </div>

                            {# Barrierefreiheits-Icons #}
                            <div class="flex gap-2 mt-3 flex-wrap">
                                {% if restaurant.isWheelchairAccessible %}
                                    <span title="Rollstuhlgerecht" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">♿</span>
                                {% endif %}
                                {% if restaurant.hasAccessibleToilet %}
                                    <span title="Barrierefreies WC" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">🚻</span>
                                {% endif %}
                                {% if restaurant.allowsAssistanceDogs %}
                                    <span title="Assistenzhund erlaubt" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">🐕</span>
                                {% endif %}
                                {% if restaurant.hasBrightLighting %}
                                    <span title="Helle Beleuchtung" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">💡</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 mt-auto">
                            <a href="{{ path('app_restaurant_show', {id: restaurant.id}) }}" class="block text-center text-sm font-semibold text-purple-600 hover:text-purple-800">Details ansehen</a>
                        </div>
                    </article>
                {% else %}
                    <div class="col-span-3 text-center py-12 text-gray-500">
                        <p class="text-lg">Noch keine Restaurants eingetragen.</p>
                    </div>
                {% endfor %}
            </div>

            <div class="text-center mt-10">
                <a href="{{ path('app_restaurant_index') }}" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-bold px-8 py-3 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    Alle Restaurants ansehen
                </a>
            </div>
        </div>
    </section>

    {# === WARUM ENDLECH.LU? === #}
    <section class="bg-white py-16">
        <div class="container mx-auto px-4">
            <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-12">Warum Endlech.lu?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">

                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
                    <div class="w-12 h-12 bg-cyan-100 text-cyan-600 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-gray-800 mb-2">Community-geprüft</h3>
                    <p class="text-sm text-gray-500">Echte Bewertungen von echten Besuchern. Keine Werbung, keine bezahlten Einträge.</p>
                </div>

                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
                    <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-gray-800 mb-2">Detaillierte Kriterien</h3>
                    <p class="text-sm text-gray-500">Rollstuhl, WC, Assistenzhunde, Beleuchtung — alles auf einen Blick.</p>
                </div>

                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
                    <div class="w-12 h-12 bg-cyan-100 text-cyan-600 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-gray-800 mb-2">100% Luxemburg</h3>
                    <p class="text-sm text-gray-500">Speziell für die Luxemburger Gastronomie. Lokal, relevant, aktuell.</p>
                </div>

            </div>
        </div>
    </section>

    {# === CTA BANNER === #}
    <section class="bg-linear-to-r from-purple-700 to-cyan-600 py-16">
        <div class="container mx-auto px-4 text-center">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Kennst du ein barrierefreies Restaurant?</h2>
            <p class="text-purple-100 text-lg mb-8 max-w-xl mx-auto">Hilf uns, die Plattform zu erweitern und Luxemburg barrierefreier zu machen.</p>
            <a href="{{ path('app_register') }}" class="inline-block bg-white text-purple-700 font-bold px-8 py-3 rounded-full shadow-lg hover:shadow-xl transition transform hover:-translate-y-0.5">
                Restaurant vorschlagen
            </a>
        </div>
    </section>

{% endblock %}
