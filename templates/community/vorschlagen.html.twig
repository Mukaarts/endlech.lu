{% extends 'base.html.twig' %}

{% block title %}{{ 'community.suggest.title'|trans }}{% endblock %}

{# Ermittle den ersten Step mit Fehlern #}
{% set error_step = 0 %}
{% if not form.vars.valid %}
    {% set step1_fields = ['name', 'city', 'cuisine', 'emoji'] %}
    {% set step2_fields = ['isWheelchairAccessible', 'hasAccessibleToilet', 'allowsAssistanceDogs', 'hasBrightLighting', 'hasChangingTable', 'hasDisabledParking'] %}
    {% set step3_fields = ['isVegan', 'isVegetarian', 'isHalal', 'acceptsCash', 'acceptsCard', 'acceptsPayconiq'] %}
    {% set step4_fields = ['phone', 'email', 'website', 'instagramUrl', 'facebookUrl', 'tiktokUrl', 'spokenLanguages'] %}
    {% set step5_fields = ['notes'] %}

    {% for field in step1_fields %}
        {% if form[field] is defined and form[field].vars.errors|length > 0 and error_step == 0 %}
            {% set error_step = 1 %}
        {% endif %}
    {% endfor %}
    {% if error_step == 0 %}
        {% for field in step2_fields %}
            {% if form[field] is defined and form[field].vars.errors|length > 0 and error_step == 0 %}
                {% set error_step = 2 %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if error_step == 0 %}
        {% for field in step3_fields %}
            {% if form[field] is defined and form[field].vars.errors|length > 0 and error_step == 0 %}
                {% set error_step = 3 %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if error_step == 0 %}
        {% for field in step4_fields %}
            {% if form[field] is defined and form[field].vars.errors|length > 0 and error_step == 0 %}
                {% set error_step = 4 %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if error_step == 0 %}
        {% for field in step5_fields %}
            {% if form[field] is defined and form[field].vars.errors|length > 0 and error_step == 0 %}
                {% set error_step = 5 %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endif %}

{% block body %}
<div class="container mx-auto px-4 py-12 max-w-2xl">

    {# Header #}
    <div class="text-center mb-10">
        <div class="text-5xl mb-4">🏪</div>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">{{ 'community.suggest.heading'|trans }}</h1>
        <p class="text-gray-600 text-lg">
            {{ 'community.suggest.text'|trans }}
        </p>
    </div>

    {# Formular-Karte #}
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8"
         data-controller="suggestion-wizard"
         data-suggestion-wizard-current-value="{{ error_step > 0 ? error_step : 1 }}"
         data-suggestion-wizard-total-value="5">

        {# Step-Indikator #}
        <nav class="mb-8">
            <ol class="flex items-center w-full">
                {% set step_labels = {
                    1: 'community.suggest.step_basic'|trans,
                    2: 'community.suggest.step_accessibility'|trans,
                    3: 'community.suggest.step_dietary_payment'|trans,
                    4: 'community.suggest.step_contact'|trans,
                    5: 'community.suggest.step_notes'|trans,
                } %}
                {% for i in 1..5 %}
                    <li class="flex items-center {{ i < 5 ? 'flex-1' : '' }}"
                        data-suggestion-wizard-target="indicator">
                        <button type="button"
                                class="flex flex-col items-center gap-1 cursor-pointer group"
                                data-action="suggestion-wizard#goTo"
                                data-step="{{ i }}">
                            <span data-circle
                                  class="flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold transition-colors {{ i == 1 ? 'bg-cyan-600 text-white' : 'bg-gray-200 text-gray-500' }}">
                                {{ i }}
                            </span>
                            <span data-label
                                  class="text-xs hidden sm:block transition-colors {{ i == 1 ? 'text-cyan-700 font-semibold' : 'text-gray-400' }}">
                                {{ step_labels[i] }}
                            </span>
                        </button>
                        {% if i < 5 %}
                            <div data-line class="flex-1 h-0.5 mx-2 bg-gray-200 transition-colors"></div>
                        {% endif %}
                    </li>
                {% endfor %}
            </ol>
        </nav>

        {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

            {# === Step 1: Grunddaten === #}
            <div data-suggestion-wizard-target="step">
                <fieldset class="space-y-5">
                    <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.step_basic'|trans }}</legend>

                    <div>
                        {{ form_label(form.name, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.city, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.city) }}
                        </div>
                        <div>
                            {{ form_label(form.cuisine, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.cuisine, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.cuisine) }}
                        </div>
                    </div>

                    <div class="w-40">
                        {{ form_label(form.emoji, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.emoji, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                        {{ form_errors(form.emoji) }}
                    </div>
                </fieldset>
            </div>

            {# === Step 2: Barrierefreiheit === #}
            <div data-suggestion-wizard-target="step" class="hidden">
                <fieldset class="space-y-3">
                    <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.step_accessibility'|trans }}</legend>
                    <p class="text-sm text-gray-500 -mt-1 mb-3">{{ 'community.suggest.accessibility_hint'|trans }}</p>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.isWheelchairAccessible, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">♿ {{ 'community.suggest.wheelchair'|trans }}</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.hasAccessibleToilet, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">🚻 {{ 'community.suggest.toilet'|trans }}</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.allowsAssistanceDogs, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">🐕 {{ 'community.suggest.dogs'|trans }}</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.hasBrightLighting, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">💡 {{ 'community.suggest.lighting'|trans }}</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.hasChangingTable, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">🍼 {{ 'community.suggest.changing_table'|trans }}</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        {{ form_widget(form.hasDisabledParking, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                        <span class="text-sm text-gray-600 group-hover:text-cyan-700">🅿️ {{ 'community.suggest.disabled_parking'|trans }}</span>
                    </label>
                </fieldset>
            </div>

            {# === Step 3: Ernährung & Zahlung === #}
            <div data-suggestion-wizard-target="step" class="hidden">
                <div class="space-y-6">
                    {# Ernährungsoptionen #}
                    <fieldset class="space-y-3">
                        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.dietary'|trans }}</legend>
                        <p class="text-sm text-gray-500 -mt-1 mb-3">{{ 'community.suggest.dietary_hint'|trans }}</p>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.isVegan, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">🌱 {{ 'form.vegan'|trans }}</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.isVegetarian, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">🥗 {{ 'form.vegetarian'|trans }}</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.isHalal, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">🍖 {{ 'form.halal'|trans }}</span>
                        </label>
                    </fieldset>

                    {# Zahlungsmethoden #}
                    <fieldset class="space-y-3">
                        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.payment'|trans }}</legend>
                        <p class="text-sm text-gray-500 -mt-1 mb-3">{{ 'community.suggest.payment_hint'|trans }}</p>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.acceptsCash, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">💵 {{ 'form.accepts_cash'|trans }}</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.acceptsCard, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">💳 {{ 'form.accepts_card'|trans }}</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            {{ form_widget(form.acceptsPayconiq, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                            <span class="text-sm text-gray-600 group-hover:text-cyan-700">📱 {{ 'form.accepts_payconiq'|trans }}</span>
                        </label>
                    </fieldset>
                </div>
            </div>

            {# === Step 4: Kontakt & Sprachen === #}
            <div data-suggestion-wizard-target="step" class="hidden">
                <div class="space-y-6">
                    {# Kontaktdaten #}
                    <fieldset class="space-y-5">
                        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.contact'|trans }}</legend>
                        <p class="text-sm text-gray-500 -mt-1 mb-3">{{ 'community.suggest.contact_hint'|trans }}</p>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                                {{ form_widget(form.phone, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                                {{ form_errors(form.phone) }}
                            </div>
                            <div>
                                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                                {{ form_widget(form.email, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                                {{ form_errors(form.email) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(form.website, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.website, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.website) }}
                        </div>
                    </fieldset>

                    {# Social Media #}
                    <fieldset class="space-y-5">
                        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.social_media'|trans }}</legend>

                        <div>
                            {{ form_label(form.instagramUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.instagramUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.instagramUrl) }}
                        </div>

                        <div>
                            {{ form_label(form.facebookUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.facebookUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.facebookUrl) }}
                        </div>

                        <div>
                            {{ form_label(form.tiktokUrl, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.tiktokUrl, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition'}}) }}
                            {{ form_errors(form.tiktokUrl) }}
                        </div>
                    </fieldset>

                    {# Sprachen #}
                    <fieldset class="space-y-3">
                        <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.languages'|trans }}</legend>

                        <div class="flex flex-wrap gap-4">
                            {% for child in form.spokenLanguages %}
                                <label class="flex items-center gap-2 cursor-pointer group">
                                    {{ form_widget(child, {'attr': {'class': 'rounded text-cyan-600 focus:ring-cyan-500 border-gray-300'}}) }}
                                    <span class="text-sm text-gray-600 group-hover:text-cyan-700">{{ child.vars.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </fieldset>
                </div>
            </div>

            {# === Step 5: Notizen & Absenden === #}
            <div data-suggestion-wizard-target="step" class="hidden">
                <fieldset class="space-y-5">
                    <legend class="text-lg font-bold text-gray-700 border-b border-gray-200 pb-2 mb-4">{{ 'community.suggest.step_notes'|trans }}</legend>

                    <div>
                        {{ form_label(form.notes, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.notes, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 focus:outline-none transition resize-none'}}) }}
                        {{ form_errors(form.notes) }}
                    </div>
                </fieldset>
            </div>

            {# Navigation #}
            <div class="pt-4 border-t border-gray-200 flex items-center gap-4">
                <button type="button"
                        data-suggestion-wizard-target="prevButton"
                        data-action="suggestion-wizard#prev"
                        class="hidden text-sm font-semibold text-gray-500 hover:text-gray-700 transition cursor-pointer">
                    {{ 'community.suggest.prev'|trans }}
                </button>

                <button type="button"
                        data-suggestion-wizard-target="nextButton"
                        data-action="suggestion-wizard#next"
                        class="bg-cyan-600 hover:bg-cyan-700 text-white font-bold px-8 py-3 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5 cursor-pointer">
                    {{ 'community.suggest.next'|trans }}
                </button>

                <button type="submit"
                        data-suggestion-wizard-target="submitButton"
                        class="hidden bg-cyan-600 hover:bg-cyan-700 text-white font-bold px-8 py-3 rounded-full shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    {{ 'community.suggest.submit'|trans }}
                </button>

                <a href="{{ path('app_restaurant_index') }}" class="text-sm font-semibold text-gray-500 hover:text-gray-700 transition ml-auto">
                    {{ 'community.suggest.cancel'|trans }}
                </a>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
