{% extends 'base.html.twig' %}

{% block title %}{{ 'about.title'|trans }}{% endblock %}

{% block body %}
    {# Hero #}
    <section class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-16">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{{ 'about.heading'|trans }}</h1>
            <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto">
                {{ 'about.subtitle'|trans }}
            </p>
        </div>
    </section>

    {# Story #}
    <section class="py-16 bg-gray-50">
        <div class="max-w-3xl mx-auto px-4">

            {# Founder-Panel #}
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 mb-6">
                <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
                    {# Avatar #}
                    <div class="flex-shrink-0">
                        <div class="w-20 h-20 rounded-full bg-linear-to-br from-cyan-500 to-purple-600 flex items-center justify-center text-white text-2xl font-extrabold shadow">
                            MF
                        </div>
                    </div>
                    {# Info #}
                    <div class="flex-1 text-center sm:text-left">
                        <p class="text-xs font-semibold text-cyan-600 uppercase tracking-widest mb-1">{{ 'about.founder'|trans }}</p>
                        <h2 class="text-2xl font-bold text-gray-900 mb-1">Michael Ferreira</h2>
                        <p class="text-gray-700 leading-relaxed mb-4">
                            {{ 'about.founder_bio'|trans }}
                        </p>
                        <div class="flex flex-wrap justify-center sm:justify-start gap-2 mb-4">
                            <span class="inline-flex items-center gap-1.5 bg-cyan-50 text-cyan-700 text-sm font-medium px-3 py-1 rounded-full border border-cyan-200">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                {{ 'about.tag_age'|trans }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 bg-purple-50 text-purple-700 text-sm font-medium px-3 py-1 rounded-full border border-purple-200">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                                {{ 'about.tag_sma'|trans }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 bg-cyan-50 text-cyan-700 text-sm font-medium px-3 py-1 rounded-full border border-cyan-200">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                                {{ 'about.tag_programmer'|trans }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 bg-purple-50 text-purple-700 text-sm font-medium px-3 py-1 rounded-full border border-purple-200">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {{ 'about.tag_photographer'|trans }}
                            </span>
                        </div>
                        <div class="flex flex-wrap justify-center sm:justify-start gap-3">
                            <a href="https://github.com/Mukaarts" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                                </svg>
                                GitHub
                            </a>
                            <a href="https://www.linkedin.com/in/michael-ferreira-2b53449a/" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-[#0A66C2] transition">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                                LinkedIn
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 md:p-12">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ 'about.story_title'|trans }}</h2>

                <p class="text-gray-700 leading-relaxed mb-8">
                    {{ 'about.story_intro'|trans }}
                </p>

                {# Timeline #}
                <div class="relative">
                    {# Vertical line #}
                    <div class="absolute left-5 top-0 bottom-0 w-0.5 bg-gray-200"></div>

                    <div class="space-y-10 pl-14">

                        {# 2018 #}
                        <div class="relative">
                            <div class="absolute -left-9 top-1 w-8 h-8 rounded-full bg-cyan-600 flex items-center justify-center">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/>
                                </svg>
                            </div>
                            <p class="text-sm font-semibold text-cyan-600 uppercase tracking-wide mb-1">2018</p>
                            <h3 class="text-lg font-bold text-gray-900 mb-2">{{ 'about.timeline_2018_title'|trans }}</h3>
                            <p class="text-gray-700 leading-relaxed">
                                {{ 'about.timeline_2018_text'|trans }}
                            </p>
                        </div>

                        {# 2020–2021 #}
                        <div class="relative">
                            <div class="absolute -left-9 top-1 w-8 h-8 rounded-full bg-purple-600 flex items-center justify-center">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <p class="text-sm font-semibold text-purple-600 uppercase tracking-wide mb-1">2020 – 2021</p>
                            <h3 class="text-lg font-bold text-gray-900 mb-2">{{ 'about.timeline_2020_title'|trans }}</h3>
                            <p class="text-gray-700 leading-relaxed">
                                {{ 'about.timeline_2020_text'|trans }}
                            </p>
                        </div>

                        {# Pause #}
                        <div class="relative">
                            <div class="absolute -left-9 top-1 w-8 h-8 rounded-full bg-gray-400 flex items-center justify-center">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-1">2022 – 2024</p>
                            <h3 class="text-lg font-bold text-gray-900 mb-2">{{ 'about.timeline_2022_title'|trans }}</h3>
                            <p class="text-gray-700 leading-relaxed">
                                {{ 'about.timeline_2022_text'|trans }}
                            </p>
                        </div>

                        {# Ende 2025 #}
                        <div class="relative">
                            <div class="absolute -left-9 top-1 w-8 h-8 rounded-full bg-cyan-600 flex items-center justify-center">
                                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                                </svg>
                            </div>
                            <p class="text-sm font-semibold text-cyan-600 uppercase tracking-wide mb-1">Ende 2025</p>
                            <h3 class="text-lg font-bold text-gray-900 mb-2">{{ 'about.timeline_2025_title'|trans }}</h3>
                            <p class="text-gray-700 leading-relaxed">
                                {{ 'about.timeline_2025_text'|trans }}
                            </p>
                        </div>

                    </div>
                </div>
            </div>

            {# Mission #}
            <div class="mt-8 bg-linear-to-r from-cyan-600 to-purple-700 rounded-2xl p-8 text-white text-center">
                <h2 class="text-2xl font-bold mb-3">{{ 'about.mission_title'|trans }}</h2>
                <p class="text-white/90 leading-relaxed max-w-xl mx-auto">
                    {{ 'about.mission_text'|trans }}
                </p>
                <a href="{{ path('app_restaurant_index') }}"
                   class="inline-block mt-6 bg-white text-purple-700 font-semibold px-8 py-3 rounded-full shadow hover:shadow-md hover:-translate-y-0.5 transition">
                    {{ 'about.mission_cta'|trans }}
                </a>
            </div>

        </div>
    </section>
{% endblock %}
