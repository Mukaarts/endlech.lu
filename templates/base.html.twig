<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Endlech.lu{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# hreflang-Tags für SEO #}
    {% set _current_route = app.request.attributes.get('_route') %}
    {% set _current_params = app.request.attributes.get('_route_params', {}) %}
    {% if _current_route and _current_route != 'app_root' %}
        {% for locale in ['lb', 'de', 'fr', 'en'] %}
            <link rel="alternate" hreflang="{{ locale }}" href="{{ url(_current_route, _current_params|merge({'_locale': locale})) }}">
        {% endfor %}
        <link rel="alternate" hreflang="x-default" href="{{ url(_current_route, _current_params|merge({'_locale': 'lb'})) }}">
    {% endif %}

    {# Hier laden wir CSS/JS via Webpack Encore #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body class="bg-gray-50 text-gray-800 flex flex-col min-h-screen font-sans">

{# === HEADER / NAVIGATION === #}
<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
    <div class="container mx-auto px-4 h-20 flex items-center justify-between">

        {# 1. Logo Bereich #}
        <a href="{{ path('app_home') }}" class="flex items-center gap-3 hover:opacity-90 transition">
            {# Logo Bild #}
            <img src="{{ asset('images/logo.png') }}" alt="Endlech.lu Logo" class="h-12 w-auto object-contain">

            {# Text Logo (optional, falls Bild nicht lädt) #}
            <span class="hidden md:block text-2xl font-bold text-cyan-600 tracking-tight">
                        Endlech<span class="text-purple-600">.lu</span>
                    </span>
        </a>

        {# 2. Desktop Navigation #}
        <nav class="hidden md:flex items-center space-x-8">
            <a href="{{ path('app_restaurant_index') }}" class="text-gray-600 font-medium hover:text-cyan-600 transition">
                {{ 'nav.find_restaurants'|trans }}
            </a>
            <a href="{{ path('app_about') }}" class="text-gray-600 font-medium hover:text-cyan-600 transition">
                {{ 'nav.about'|trans }}
            </a>
            <a href="{{ path('community_vorschlagen') }}" class="text-gray-600 font-medium hover:text-cyan-600 transition">
                {{ 'nav.suggest_restaurant'|trans }}
            </a>
        </nav>

        {# 3. Buttons (Login / Register / Benutzer / Sprache) #}
        <div class="flex items-center gap-4">
            {# Language Switcher #}
            <div class="hidden md:block">
                {% include 'partials/_language_switcher.html.twig' %}
            </div>
            {% if app.user %}
                <a href="{{ path('app_profile') }}" class="hidden md:inline-flex items-center gap-2 text-sm text-gray-600 hover:text-purple-600 transition">
                    {% include 'partials/_avatar.html.twig' with {user: app.user, size: 'sm'} %}
                    {{ app.user.name }}
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="hidden md:inline-block text-sm font-semibold text-purple-600 hover:text-purple-800 transition">
                        {{ 'nav.admin'|trans }}
                    </a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="hidden md:inline-block text-sm font-semibold text-gray-500 hover:text-purple-600">
                    {{ 'nav.logout'|trans }}
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" class="hidden md:inline-block text-sm font-semibold text-gray-500 hover:text-purple-600">
                    {{ 'nav.login'|trans }}
                </a>
                <a href="{{ path('app_register') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-5 py-2.5 rounded-full font-bold shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    {{ 'nav.join'|trans }}
                </a>
            {% endif %}
        </div>
    </div>
</header>

{# === FLASH NACHRICHTEN === #}
<div class="container mx-auto px-4 mt-4">
    {% include 'partials/_flash_messages.html.twig' %}
</div>

{# === HAUPTINHALT (Hier wird index.html.twig reingeladen) === #}
<main class="flex-grow">
    {% block body %}{% endblock %}
</main>

{# === FOOTER === #}
<footer class="bg-gray-900 text-gray-300 py-12 mt-12">
    <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">

        {# Spalte 1 #}
        <div>
            <div class="flex items-center gap-2 mb-4 text-white font-bold text-lg">
                <span class="text-cyan-400">Endlech</span>.lu
            </div>
            <p class="mb-4">
                {{ 'footer.tagline'|trans }}
            </p>
            <a href="https://github.com/Mukaarts/endlech.lu" class="inline-flex items-center gap-2 text-gray-400 hover:text-cyan-400 transition" target="_blank" rel="noopener noreferrer">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
                {{ 'footer.open_source'|trans }}
            </a>
        </div>

        {# Spalte 2 #}
        <div>
            <h4 class="text-white font-bold mb-4 uppercase tracking-wider">{{ 'footer.links'|trans }}</h4>
            <ul class="space-y-2">
                <li><a href="#" class="hover:text-cyan-400 transition">{{ 'footer.search_restaurants'|trans }}</a></li>
                <li><a href="{{ path('app_kriterien') }}" class="hover:text-cyan-400 transition">{{ 'footer.accessibility_criteria'|trans }}</a></li>
                <li><a href="{{ path('app_impressum') }}" class="hover:text-cyan-400 transition">{{ 'footer.legal'|trans }}</a></li>
                <li><a href="https://endlech.userjot.com/?cursor=1&amp;order=top&amp;limit=10" class="hover:text-cyan-400 transition" target="_blank" rel="noopener noreferrer">{{ 'footer.feedback'|trans }}</a></li>
            </ul>
        </div>

        {# Spalte 3 #}
        <div>
            <h4 class="text-white font-bold mb-4 uppercase tracking-wider">{{ 'footer.contact_title'|trans }}</h4>
            <p>{{ 'footer.help_improve'|trans }}</p>
            <a href="mailto:info@endlech.lu" class="block mt-2 text-cyan-400 hover:underline">info@endlech.lu</a>
        </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-xs text-gray-500">
        &copy; {{ 'now'|date('Y') }} Endlech.lu - {{ 'footer.copyright'|trans }}
    </div>
</footer>

</body>
</html>
