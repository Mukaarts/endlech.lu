{% extends 'base.html.twig' %}

{% block title %}Registrieren - Endlech.lu{% endblock %}

{% block body %}
<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">

            {# Titel #}
            <div class="text-center mb-8">
                <h1 class="text-2xl font-bold text-gray-900 mb-2">Konto erstellen</h1>
                <p class="text-gray-500 text-sm">Werde Teil der Endlech.lu-Community</p>
            </div>

            {% include 'partials/_flash_messages.html.twig' %}

            {{ form_start(registrationForm, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

                {# Name #}
                <div>
                    {{ form_label(registrationForm.name, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                    {{ form_errors(registrationForm.name, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                </div>

                {# E-Mail #}
                <div>
                    {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                    {{ form_errors(registrationForm.email, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                </div>

                {# Passwort #}
                <div>
                    {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                    {{ form_errors(registrationForm.plainPassword.first, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                </div>

                {# Passwort bestätigen #}
                <div>
                    {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-purple-500 focus:border-purple-500 focus:outline-none transition'}}) }}
                    {{ form_errors(registrationForm.plainPassword.second, {'attr': {'class': 'text-red-600 text-xs mt-1'}}) }}
                </div>

                {# Absenden #}
                <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-lg shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    Registrieren
                </button>

            {{ form_end(registrationForm) }}

            {# Link zu Login #}
            <p class="text-center text-sm text-gray-500 mt-6">
                Bereits ein Konto?
                <a href="{{ path('app_login') }}" class="text-purple-600 font-semibold hover:text-purple-800 transition">Anmelden</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
