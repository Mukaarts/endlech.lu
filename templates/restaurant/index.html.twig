{% extends 'base.html.twig' %}

{% block title %}Restaurants – Endlech.lu{% endblock %}

{% block body %}

    <div class="min-h-screen bg-gray-50">
        {# --- HERO SECTION --- #}
        <div class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-12 shadow-md">
            <div class="container mx-auto px-4">
                <h1 class="text-3xl font-bold mb-2">Restaurants in Luxemburg</h1>
                <p class="text-cyan-100 text-lg">{{ total }} barrierefreie Orte entdecken.</p>
            </div>
        </div>

        {# --- MAIN LAYOUT MIT PANELS --- #}
        <div class="container mx-auto px-4 py-8">
            <div class="flex flex-col lg:flex-row gap-8">

                {# === LINKES PANEL: FILTER (Sidebar) === #}
                <aside class="w-full lg:w-1/4">
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 sticky top-24">
                        <div class="flex items-center gap-2 mb-6 text-purple-700">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                            <h3 class="font-bold text-lg">Filter</h3>
                        </div>

                        <form method="get" action="{{ path('app_restaurant_index') }}">
                            <input type="hidden" name="sort" value="{{ sort }}">

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-2" for="filter-city">Ort</label>
                                <input type="text" id="filter-city" name="city" value="{{ filters.city }}" placeholder="Stadt..." class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-purple-500 focus:outline-none">
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-2" for="filter-cuisine">Küche</label>
                                <input type="text" id="filter-cuisine" name="cuisine" value="{{ filters.cuisine }}" placeholder="z.B. Italienisch" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-purple-500 focus:outline-none">
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Status</label>
                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="open" value="1"
                                           class="rounded text-green-600 focus:ring-green-500 border-gray-300"
                                           {{ filters.open ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-green-700">🟢 Nur geöffnete Lokale</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="checkbox" name="verified" value="1"
                                           class="rounded text-cyan-600 focus:ring-cyan-500 border-gray-300"
                                           {{ filters.verified ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-cyan-700">✓ Nur verifizierte Lokale</span>
                                </label>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Bedürfnisse</label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="wheelchair" value="1"
                                           class="rounded text-purple-600 focus:ring-purple-500 border-gray-300"
                                           {{ filters.wheelchair ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-purple-700">♿ Rollstuhl (stufenlos)</span>
                                </label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="toilet" value="1"
                                           class="rounded text-purple-600 focus:ring-purple-500 border-gray-300"
                                           {{ filters.toilet ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-purple-700">🚻 Barrierefreies WC</span>
                                </label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="dogs" value="1"
                                           class="rounded text-purple-600 focus:ring-purple-500 border-gray-300"
                                           {{ filters.dogs ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-purple-700">🐕 Assistenzhund erlaubt</span>
                                </label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="lighting" value="1"
                                           class="rounded text-purple-600 focus:ring-purple-500 border-gray-300"
                                           {{ filters.lighting ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-purple-700">💡 Helle Beleuchtung</span>
                                </label>

                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="checkbox" name="changing_table" value="1"
                                           class="rounded text-purple-600 focus:ring-purple-500 border-gray-300"
                                           {{ filters.changing_table ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-purple-700">🍼 Wickeltisch</span>
                                </label>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Ernährung</label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="vegan" value="1"
                                           class="rounded text-emerald-600 focus:ring-emerald-500 border-gray-300"
                                           {{ filters.vegan ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-emerald-700">🌱 Vegan</span>
                                </label>

                                <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                    <input type="checkbox" name="vegetarian" value="1"
                                           class="rounded text-emerald-600 focus:ring-emerald-500 border-gray-300"
                                           {{ filters.vegetarian ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-emerald-700">🥗 Vegetarisch</span>
                                </label>

                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="checkbox" name="halal" value="1"
                                           class="rounded text-emerald-600 focus:ring-emerald-500 border-gray-300"
                                           {{ filters.halal ? 'checked' : '' }}>
                                    <span class="text-sm text-gray-600 group-hover:text-emerald-700">☪️ Halal</span>
                                </label>
                            </div>

                            <div class="mb-6">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Sprachen</label>
                                {% for lang in languages %}
                                    <label class="flex items-center gap-3 mb-2 cursor-pointer group">
                                        <input type="checkbox" name="lang_{{ lang.value }}" value="1"
                                               class="rounded text-blue-600 focus:ring-blue-500 border-gray-300"
                                               {{ lang.value in filters.lang ? 'checked' : '' }}>
                                        <span class="text-sm text-gray-600 group-hover:text-blue-700">{{ lang.flag }} {{ lang.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>

                            <button type="submit" class="w-full bg-gray-900 hover:bg-black text-white font-medium py-2 rounded-lg transition">
                                Filter anwenden
                            </button>

                            {% set activeCount = (filters.verified ? 1 : 0) + (filters.wheelchair ? 1 : 0) + (filters.toilet ? 1 : 0) + (filters.dogs ? 1 : 0) + (filters.lighting ? 1 : 0) + (filters.changing_table ? 1 : 0) + (filters.open ? 1 : 0) + (filters.vegan ? 1 : 0) + (filters.vegetarian ? 1 : 0) + (filters.halal ? 1 : 0) + (filters.city ? 1 : 0) + (filters.cuisine ? 1 : 0) + (filters.lang|length) %}
                            {% if activeCount > 0 %}
                                <a href="{{ path('app_restaurant_index', {sort: sort}) }}" class="block text-center text-xs text-red-500 hover:text-red-700 mt-3 transition">
                                    × Alle Filter zurücksetzen ({{ activeCount }})
                                </a>
                            {% endif %}
                        </form>
                    </div>
                </aside>

                {# === RECHTES PANEL: RESTAURANTS (Grid) === #}
                <main class="w-full lg:w-3/4">

                    {# Sortierung & Ergebnisanzahl #}
                    {% set filterParams = {
                        verified:       filters.verified       ? 1 : null,
                        wheelchair:     filters.wheelchair     ? 1 : null,
                        toilet:         filters.toilet         ? 1 : null,
                        dogs:           filters.dogs           ? 1 : null,
                        lighting:       filters.lighting       ? 1 : null,
                        changing_table: filters.changing_table ? 1 : null,
                        open:           filters.open           ? 1 : null,
                        vegan:          filters.vegan          ? 1 : null,
                        vegetarian:     filters.vegetarian     ? 1 : null,
                        halal:          filters.halal          ? 1 : null,
                        city:           filters.city ?: null,
                        cuisine:        filters.cuisine ?: null
                    } %}
                    {% for langVal in filters.lang %}
                        {% set filterParams = filterParams|merge({('lang_' ~ langVal): 1}) %}
                    {% endfor %}
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-xl font-bold text-gray-800">{{ total }} Ergebnisse gefunden</h2>
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_restaurant_index', {sort: 'rating', page: 1}|merge(filterParams)) }}"
                               class="px-3 py-1.5 text-sm rounded-lg border transition {{ sort == 'rating' ? 'bg-purple-600 text-white border-purple-600' : 'bg-white text-gray-700 border-gray-300 hover:border-purple-400' }}">
                                Beste Bewertung
                            </a>
                            <a href="{{ path('app_restaurant_index', {sort: 'name', page: 1}|merge(filterParams)) }}"
                               class="px-3 py-1.5 text-sm rounded-lg border transition {{ sort == 'name' ? 'bg-purple-600 text-white border-purple-600' : 'bg-white text-gray-700 border-gray-300 hover:border-purple-400' }}">
                                A – Z
                            </a>
                            <a href="{{ path('app_restaurant_index', {sort: 'newest', page: 1}|merge(filterParams)) }}"
                               class="px-3 py-1.5 text-sm rounded-lg border transition {{ sort == 'newest' ? 'bg-purple-600 text-white border-purple-600' : 'bg-white text-gray-700 border-gray-300 hover:border-purple-400' }}">
                                Neueste
                            </a>
                        </div>
                    </div>

                    {# Aktive Filter als Chips #}
                    {% if activeCount > 0 %}
                    <div class="flex flex-wrap gap-2 mb-4">
                        {% if filters.open %}<span class="inline-flex items-center text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full border border-green-200">🟢 Geöffnet</span>{% endif %}
                        {% if filters.verified %}<span class="inline-flex items-center text-xs bg-cyan-100 text-cyan-700 px-2 py-1 rounded-full border border-cyan-200">✓ Verifiziert</span>{% endif %}
                        {% if filters.wheelchair %}<span class="inline-flex items-center text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full border border-purple-200">♿ Rollstuhlgerecht</span>{% endif %}
                        {% if filters.toilet %}<span class="inline-flex items-center text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full border border-purple-200">🚻 Barrierefreies WC</span>{% endif %}
                        {% if filters.dogs %}<span class="inline-flex items-center text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full border border-purple-200">🐕 Assistenzhund</span>{% endif %}
                        {% if filters.lighting %}<span class="inline-flex items-center text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full border border-purple-200">💡 Helle Beleuchtung</span>{% endif %}
                        {% if filters.changing_table %}<span class="inline-flex items-center text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full border border-purple-200">🍼 Wickeltisch</span>{% endif %}
                        {% if filters.vegan %}<span class="inline-flex items-center text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full border border-emerald-200">🌱 Vegan</span>{% endif %}
                        {% if filters.vegetarian %}<span class="inline-flex items-center text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full border border-emerald-200">🥗 Vegetarisch</span>{% endif %}
                        {% if filters.halal %}<span class="inline-flex items-center text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full border border-emerald-200">☪️ Halal</span>{% endif %}
                        {% if filters.city %}<span class="inline-flex items-center text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded-full border border-gray-200">📍 {{ filters.city }}</span>{% endif %}
                        {% if filters.cuisine %}<span class="inline-flex items-center text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded-full border border-gray-200">🍽️ {{ filters.cuisine }}</span>{% endif %}
                        {% for langVal in filters.lang %}
                            {% for lang in languages %}
                                {% if lang.value == langVal %}
                                    <span class="inline-flex items-center text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-full border border-blue-200">{{ lang.flag }} {{ lang.label }}</span>
                                {% endif %}
                            {% endfor %}
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Restaurant-Karten #}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                        {% for restaurant in restaurants %}
                            <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition group flex flex-col">
                                <div class="h-40 bg-gray-100 relative {{ restaurant.images is empty ? 'flex items-center justify-center text-gray-300 text-5xl' : '' }}">
                                    {% if restaurant.images is not empty %}
                                        <img src="/uploads/restaurants/{{ restaurant.images.first.filename }}"
                                             alt="{{ restaurant.images.first.altText }}"
                                             class="w-full h-full object-cover">
                                    {% else %}
                                        {{ restaurant.emoji }}
                                    {% endif %}
                                    {% if restaurant.isOpen %}
                                        <span class="absolute top-3 right-3 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm">Geöffnet</span>
                                    {% else %}
                                        <span class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded shadow-sm">Geschlossen</span>
                                    {% endif %}
                                </div>
                                <div class="p-5 flex-grow">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <h3 class="text-lg font-bold text-gray-900 group-hover:text-purple-700 transition">{{ restaurant.name }}</h3>
                                                {% include 'partials/_verified_badge.html.twig' with {restaurant: restaurant} %}
                                            </div>
                                            <p class="text-sm text-gray-500">{{ restaurant.city }} &bull; {{ restaurant.cuisine }}</p>
                                        </div>
                                        {% if restaurant.rating is not null %}
                                            <div class="bg-cyan-50 text-cyan-700 px-2 py-1 rounded text-xs font-bold border border-cyan-100 shrink-0">{{ restaurant.rating }}</div>
                                        {% endif %}
                                    </div>

                                    {# Barrierefreiheits-Icons #}
                                    <div class="flex gap-2 mt-3 flex-wrap">
                                        {% if restaurant.isWheelchairAccessible %}
                                            <span title="Rollstuhlgerecht" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">♿</span>
                                        {% endif %}
                                        {% if restaurant.hasAccessibleToilet %}
                                            <span title="Barrierefreies WC" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">🚻</span>
                                        {% endif %}
                                        {% if restaurant.allowsAssistanceDogs %}
                                            <span title="Assistenzhund erlaubt" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">🐕</span>
                                        {% endif %}
                                        {% if restaurant.hasBrightLighting %}
                                            <span title="Helle Beleuchtung" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">💡</span>
                                        {% endif %}
                                        {% if restaurant.hasChangingTable %}
                                            <span title="Wickeltisch" class="text-sm bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-100">🍼</span>
                                        {% endif %}
                                        {% if restaurant.isVegan %}
                                            <span title="Vegan" class="text-sm bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded border border-emerald-100">🌱</span>
                                        {% endif %}
                                        {% if restaurant.isVegetarian %}
                                            <span title="Vegetarisch" class="text-sm bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded border border-emerald-100">🥗</span>
                                        {% endif %}
                                        {% if restaurant.isHalal %}
                                            <span title="Halal" class="text-sm bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded border border-emerald-100">☪️</span>
                                        {% endif %}
                                        {% for lang in restaurant.spokenLanguages %}
                                            <span title="{{ lang.label }}" class="text-sm bg-blue-50 text-blue-700 px-2 py-0.5 rounded border border-blue-100">{{ lang.flag }}</span>
                                        {% endfor %}
                                    </div>

                                    {% if restaurant.accessibilityNotes is not empty %}
                                        <hr class="my-4 border-gray-100">
                                        <div class="space-y-2">
                                            {% for note in restaurant.accessibilityNotes %}
                                                {% set parts = note|split(':') %}
                                                {% set type = parts|first %}
                                                {% set text = parts[1] %}
                                                {% if type == 'ok' %}
                                                    <div class="flex items-center gap-2 text-sm text-gray-600"><span class="text-green-500">✓</span> {{ text }}</div>
                                                {% elseif type == 'warn' %}
                                                    <div class="flex items-center gap-2 text-sm text-gray-600"><span class="text-yellow-500">!</span> {{ text }}</div>
                                                {% else %}
                                                    <div class="flex items-center gap-2 text-sm text-gray-600">{{ note }}</div>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 mt-auto">
                                    <a href="{{ path('app_restaurant_show', {id: restaurant.id}) }}" class="block text-center text-sm font-semibold text-purple-600 hover:text-purple-800">Details ansehen</a>
                                </div>
                            </article>
                        {% else %}
                            <div class="col-span-2 text-center py-16 text-gray-400">
                                <p class="text-5xl mb-4">🍽️</p>
                                <p class="text-lg font-medium text-gray-600">Noch keine Restaurants eingetragen.</p>
                                <p class="text-sm mt-1">Hilf uns und schlage ein Restaurant vor!</p>
                            </div>
                        {% endfor %}

                    </div>

                    {# --- PAGINATION --- #}
                    {% if lastPage > 1 %}
                        <nav class="flex justify-center items-center gap-2 mt-10" aria-label="Seitennavigation">
                            {% if currentPage > 1 %}
                                <a href="{{ path('app_restaurant_index', {sort: sort, page: currentPage - 1}|merge(filterParams)) }}"
                                   class="px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:border-purple-400 transition text-sm">
                                    ← Zurück
                                </a>
                            {% endif %}

                            {% for p in 1..lastPage %}
                                <a href="{{ path('app_restaurant_index', {sort: sort, page: p}|merge(filterParams)) }}"
                                   class="px-4 py-2 rounded-lg border text-sm transition {{ p == currentPage ? 'bg-purple-600 text-white border-purple-600 font-bold' : 'bg-white text-gray-700 border-gray-300 hover:border-purple-400' }}">
                                    {{ p }}
                                </a>
                            {% endfor %}

                            {% if currentPage < lastPage %}
                                <a href="{{ path('app_restaurant_index', {sort: sort, page: currentPage + 1}|merge(filterParams)) }}"
                                   class="px-4 py-2 rounded-lg border border-gray-300 bg-white text-gray-700 hover:border-purple-400 transition text-sm">
                                    Weiter →
                                </a>
                            {% endif %}
                        </nav>
                        <p class="text-center text-sm text-gray-400 mt-3">Seite {{ currentPage }} von {{ lastPage }}</p>
                    {% endif %}

                </main>
            </div>
        </div>
    </div>

{% endblock %}
