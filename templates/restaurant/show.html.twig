{% extends 'base.html.twig' %}

{% block title %}{{ restaurant.name }} – Endlech.lu{% endblock %}

{% block body %}

    <div class="min-h-screen bg-gray-50">

        {# --- HERO SECTION: Restaurant-Emoji und Name --- #}
        <div class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-16 shadow-md">
            <div class="container mx-auto px-4 text-center">
                <div class="text-7xl mb-4">{{ restaurant.emoji }}</div>
                <h1 class="text-3xl font-bold mb-2">{{ restaurant.name }}</h1>
                <p class="text-cyan-100 text-lg">{{ restaurant.city }} &bull; {{ restaurant.cuisine }}</p>
                <div class="flex items-center justify-center gap-3 mt-4 flex-wrap">
                    {% if restaurant.isOpen %}
                        <span class="inline-block bg-green-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geöffnet</span>
                    {% else %}
                        <span class="inline-block bg-red-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geschlossen</span>
                    {% endif %}
                    {% include 'partials/_verified_badge.html.twig' with {restaurant: restaurant, size: 'lg'} %}
                </div>
            </div>
        </div>

        {# --- MAIN CONTENT --- #}
        <div class="container mx-auto px-4 py-8 max-w-3xl">

            {# Zurück-Link #}
            <a href="{{ path('app_restaurant_index') }}" class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-800 font-semibold mb-8 transition">
                ← Zurück zur Liste
            </a>

            {# --- VERIFIZIERUNGS-INFO-KARTE --- #}
            {% if restaurant.isVerified %}
            <div class="bg-cyan-50 rounded-xl border border-cyan-200 p-5 mb-6 flex items-start gap-4">
                <svg class="w-6 h-6 text-cyan-600 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
                </svg>
                <div>
                    <p class="text-sm font-bold text-cyan-800">Von Endlech.lu persönlich vor Ort geprüft</p>
                    <p class="text-xs text-cyan-600 mt-0.5">
                        Die Barrierefreiheitsangaben dieses Lokals wurden von unserem Team persönlich verifiziert.
                        {% if restaurant.verifiedAt is not null %}Geprüft am {{ restaurant.verifiedAt|date('d.m.Y') }}.{% endif %}
                    </p>
                </div>
            </div>
            {% endif %}

            {# --- BEWERTUNG --- #}
            {% if restaurant.rating is not null %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-3">Bewertung</h2>
                    <div class="flex items-center gap-3">
                        <div class="bg-cyan-50 text-cyan-700 px-4 py-2 rounded-lg text-2xl font-bold border border-cyan-100">{{ restaurant.rating }}</div>
                        <span class="text-gray-500 text-sm">von 10</span>
                    </div>
                </div>
            {% endif %}

            {# --- BARRIEREFREIHEIT (Accessibility Features) --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Barrierefreiheit</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                    {# Rollstuhlgerecht #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isWheelchairAccessible ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">♿</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isWheelchairAccessible ? 'text-green-700' : 'text-gray-400' }}">Rollstuhlgerecht</p>
                            <p class="text-xs {{ restaurant.isWheelchairAccessible ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isWheelchairAccessible ? 'Stufenloser Zugang' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Barrierefreies WC #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasAccessibleToilet ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🚻</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasAccessibleToilet ? 'text-green-700' : 'text-gray-400' }}">Barrierefreies WC</p>
                            <p class="text-xs {{ restaurant.hasAccessibleToilet ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasAccessibleToilet ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Assistenzhund #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.allowsAssistanceDogs ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🐕</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.allowsAssistanceDogs ? 'text-green-700' : 'text-gray-400' }}">Assistenzhund erlaubt</p>
                            <p class="text-xs {{ restaurant.allowsAssistanceDogs ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.allowsAssistanceDogs ? 'Willkommen' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Helle Beleuchtung #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasBrightLighting ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💡</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasBrightLighting ? 'text-green-700' : 'text-gray-400' }}">Helle Beleuchtung</p>
                            <p class="text-xs {{ restaurant.hasBrightLighting ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasBrightLighting ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- ERNÄHRUNGSOPTIONEN --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Ernährungsoptionen</h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                    {# Vegan #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isVegan ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🌱</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isVegan ? 'text-green-700' : 'text-gray-400' }}">Vegan</p>
                            <p class="text-xs {{ restaurant.isVegan ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isVegan ? 'Verfügbar' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Vegetarisch #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isVegetarian ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🥗</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isVegetarian ? 'text-green-700' : 'text-gray-400' }}">Vegetarisch</p>
                            <p class="text-xs {{ restaurant.isVegetarian ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isVegetarian ? 'Verfügbar' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Halal #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isHalal ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">☪️</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isHalal ? 'text-green-700' : 'text-gray-400' }}">Halal</p>
                            <p class="text-xs {{ restaurant.isHalal ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isHalal ? 'Verfügbar' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- ZAHLUNGSMETHODEN --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Zahlungsmethoden</h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                    {# Bargeld #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsCash ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💵</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsCash ? 'text-green-700' : 'text-gray-400' }}">Barzahlung</p>
                            <p class="text-xs {{ restaurant.acceptsCash ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsCash ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                    {# Karte #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsCard ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💳</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsCard ? 'text-green-700' : 'text-gray-400' }}">Kreditkarte / EC</p>
                            <p class="text-xs {{ restaurant.acceptsCard ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsCard ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                    {# Payconiq #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsPayconiq ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">📱</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsPayconiq ? 'text-green-700' : 'text-gray-400' }}">Payconiq</p>
                            <p class="text-xs {{ restaurant.acceptsPayconiq ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsPayconiq ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- BESTELLOPTIONEN --- #}
            {% if restaurant.orderingOptions is not empty %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Online bestellen</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {% for option in restaurant.orderingOptions %}
                            {% set platform = option.platformEnum %}
                            {% if platform %}
                                <a href="{{ platform.value == 'phone' ? 'tel:' ~ option.url : option.url }}"
                                   target="{{ platform.value == 'phone' ? '_self' : '_blank' }}"
                                   rel="{{ platform.value == 'phone' ? '' : 'noopener noreferrer' }}"
                                   class="flex items-center gap-3 p-4 rounded-lg bg-purple-50 border border-purple-100 hover:bg-purple-100 hover:border-purple-200 transition group">
                                    <span class="text-2xl">{{ platform.emoji }}</span>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-semibold text-purple-700 group-hover:text-purple-800">{{ platform.label }}</p>
                                        <p class="text-xs text-purple-500 truncate">{{ option.url }}</p>
                                    </div>
                                    <span class="text-xs font-bold text-purple-600 bg-purple-100 px-3 py-1 rounded-full group-hover:bg-purple-200 shrink-0">
                                        {{ platform.actionLabel }} →
                                    </span>
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# --- KONTAKT & SOCIAL MEDIA --- #}
            {% if restaurant.hasContactInfo %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Kontakt & Social Media</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

                        {% if restaurant.phone %}
                            <a href="tel:{{ restaurant.phone }}"
                               class="flex items-center gap-3 p-4 rounded-lg bg-green-50 border border-green-100 hover:bg-green-100 hover:border-green-200 transition group">
                                <span class="text-2xl">📞</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-green-700 group-hover:text-green-800">Telefon</p>
                                    <p class="text-xs text-green-500 truncate">{{ restaurant.phone }}</p>
                                </div>
                                <span class="text-xs font-bold text-green-600 bg-green-100 px-3 py-1 rounded-full group-hover:bg-green-200 shrink-0">
                                    Anrufen →
                                </span>
                            </a>
                        {% endif %}

                        {% if restaurant.email %}
                            <a href="mailto:{{ restaurant.email }}"
                               class="flex items-center gap-3 p-4 rounded-lg bg-blue-50 border border-blue-100 hover:bg-blue-100 hover:border-blue-200 transition group">
                                <span class="text-2xl">✉️</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-blue-700 group-hover:text-blue-800">E-Mail</p>
                                    <p class="text-xs text-blue-500 truncate">{{ restaurant.email }}</p>
                                </div>
                                <span class="text-xs font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full group-hover:bg-blue-200 shrink-0">
                                    Schreiben →
                                </span>
                            </a>
                        {% endif %}

                        {% if restaurant.website %}
                            <a href="{{ restaurant.website }}" target="_blank" rel="noopener noreferrer"
                               class="flex items-center gap-3 p-4 rounded-lg bg-cyan-50 border border-cyan-100 hover:bg-cyan-100 hover:border-cyan-200 transition group">
                                <span class="text-2xl">🌐</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-cyan-700 group-hover:text-cyan-800">Webseite</p>
                                    <p class="text-xs text-cyan-500 truncate">{{ restaurant.website }}</p>
                                </div>
                                <span class="text-xs font-bold text-cyan-600 bg-cyan-100 px-3 py-1 rounded-full group-hover:bg-cyan-200 shrink-0">
                                    Besuchen →
                                </span>
                            </a>
                        {% endif %}

                        {% if restaurant.instagramUrl %}
                            <a href="{{ restaurant.instagramUrl }}" target="_blank" rel="noopener noreferrer"
                               class="flex items-center gap-3 p-4 rounded-lg bg-pink-50 border border-pink-100 hover:bg-pink-100 hover:border-pink-200 transition group">
                                <svg class="w-7 h-7 text-pink-600 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                                </svg>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-pink-700 group-hover:text-pink-800">Instagram</p>
                                    <p class="text-xs text-pink-500 truncate">{{ restaurant.instagramUrl }}</p>
                                </div>
                                <span class="text-xs font-bold text-pink-600 bg-pink-100 px-3 py-1 rounded-full group-hover:bg-pink-200 shrink-0">
                                    Folgen →
                                </span>
                            </a>
                        {% endif %}

                        {% if restaurant.facebookUrl %}
                            <a href="{{ restaurant.facebookUrl }}" target="_blank" rel="noopener noreferrer"
                               class="flex items-center gap-3 p-4 rounded-lg bg-blue-50 border border-blue-100 hover:bg-blue-100 hover:border-blue-200 transition group">
                                <svg class="w-7 h-7 text-blue-600 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-blue-700 group-hover:text-blue-800">Facebook</p>
                                    <p class="text-xs text-blue-500 truncate">{{ restaurant.facebookUrl }}</p>
                                </div>
                                <span class="text-xs font-bold text-blue-600 bg-blue-100 px-3 py-1 rounded-full group-hover:bg-blue-200 shrink-0">
                                    Folgen →
                                </span>
                            </a>
                        {% endif %}

                        {% if restaurant.tiktokUrl %}
                            <a href="{{ restaurant.tiktokUrl }}" target="_blank" rel="noopener noreferrer"
                               class="flex items-center gap-3 p-4 rounded-lg bg-gray-50 border border-gray-200 hover:bg-gray-100 hover:border-gray-300 transition group">
                                <svg class="w-7 h-7 text-gray-800 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                                </svg>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-gray-800 group-hover:text-gray-900">TikTok</p>
                                    <p class="text-xs text-gray-500 truncate">{{ restaurant.tiktokUrl }}</p>
                                </div>
                                <span class="text-xs font-bold text-gray-600 bg-gray-200 px-3 py-1 rounded-full group-hover:bg-gray-300 shrink-0">
                                    Folgen →
                                </span>
                            </a>
                        {% endif %}

                    </div>
                </div>
            {% endif %}

            {# --- GESPROCHENE SPRACHEN --- #}
            {% if restaurant.spokenLanguages is not empty %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Gesprochene Sprachen</h2>
                    <div class="flex flex-wrap gap-2">
                        {% for lang in restaurant.spokenLanguages %}
                            <span class="inline-flex items-center gap-1.5 text-sm bg-blue-50 text-blue-700 px-3 py-1.5 rounded-full border border-blue-100 font-medium">
                                {{ lang.flag }} {{ lang.label }}
                            </span>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# --- HINWEISE (Accessibility Notes) --- #}
            {% if restaurant.accessibilityNotes is not empty %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Hinweise zur Barrierefreiheit</h2>
                    <div class="space-y-3">
                        {% for note in restaurant.accessibilityNotes %}
                            {% set parts = note|split(':') %}
                            {% set type = parts|first %}
                            {% set text = parts[1] %}
                            {% if type == 'ok' %}
                                <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg border border-green-100">
                                    <span class="text-green-500 text-lg font-bold">✓</span>
                                    <span class="text-sm text-green-800">{{ text }}</span>
                                </div>
                            {% elseif type == 'warn' %}
                                <div class="flex items-center gap-3 p-3 bg-yellow-50 rounded-lg border border-yellow-100">
                                    <span class="text-yellow-500 text-lg font-bold">!</span>
                                    <span class="text-sm text-yellow-800">{{ text }}</span>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-100">
                                    <span class="text-sm text-gray-600">{{ note }}</span>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# --- FOTOS (Galerie mit GLightbox) --- #}
            {% if restaurant.images is not empty %}
            <section class="mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">📷 Fotos</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                    {% for image in restaurant.images %}
                    <a href="/uploads/restaurants/{{ image.filename }}"
                       class="glightbox" data-gallery="restaurant-gallery" data-description="{{ image.altText }}">
                        <img src="/uploads/restaurants/{{ image.filename }}" alt="{{ image.altText }}"
                             class="w-full h-40 object-cover rounded-xl border border-gray-200 hover:opacity-90 transition">
                    </a>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {# --- ERSTELLT AM --- #}
            <div class="text-center text-sm text-gray-400 mt-8">
                Eingetragen am {{ restaurant.createdAt|date('d.m.Y') }}
            </div>

        </div>
    </div>

{% endblock %}
