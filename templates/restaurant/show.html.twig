{% extends 'base.html.twig' %}

{% block title %}{{ restaurant.name }} – Endlech.lu{% endblock %}

{% block body %}

    <div class="min-h-screen bg-gray-50">

        {# --- HERO SECTION: Restaurant-Emoji und Name --- #}
        <div class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-16 shadow-md">
            <div class="container mx-auto px-4 text-center">
                <div class="text-7xl mb-4">{{ restaurant.emoji }}</div>
                <h1 class="text-3xl font-bold mb-2">{{ restaurant.name }}</h1>
                <p class="text-cyan-100 text-lg">{{ restaurant.city }} &bull; {{ restaurant.cuisine }}</p>
                {% if restaurant.isOpen %}
                    <span class="inline-block mt-4 bg-green-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geöffnet</span>
                {% else %}
                    <span class="inline-block mt-4 bg-red-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geschlossen</span>
                {% endif %}
            </div>
        </div>

        {# --- MAIN CONTENT --- #}
        <div class="container mx-auto px-4 py-8 max-w-3xl">

            {# Zurück-Link #}
            <a href="{{ path('app_restaurant_index') }}" class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-800 font-semibold mb-8 transition">
                ← Zurück zur Liste
            </a>

            {# --- BEWERTUNG --- #}
            {% if restaurant.rating is not null %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-3">Bewertung</h2>
                    <div class="flex items-center gap-3">
                        <div class="bg-cyan-50 text-cyan-700 px-4 py-2 rounded-lg text-2xl font-bold border border-cyan-100">{{ restaurant.rating }}</div>
                        <span class="text-gray-500 text-sm">von 10</span>
                    </div>
                </div>
            {% endif %}

            {# --- BARRIEREFREIHEIT (Accessibility Features) --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Barrierefreiheit</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                    {# Rollstuhlgerecht #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isWheelchairAccessible ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">♿</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isWheelchairAccessible ? 'text-green-700' : 'text-gray-400' }}">Rollstuhlgerecht</p>
                            <p class="text-xs {{ restaurant.isWheelchairAccessible ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isWheelchairAccessible ? 'Stufenloser Zugang' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Barrierefreies WC #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasAccessibleToilet ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🚻</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasAccessibleToilet ? 'text-green-700' : 'text-gray-400' }}">Barrierefreies WC</p>
                            <p class="text-xs {{ restaurant.hasAccessibleToilet ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasAccessibleToilet ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Assistenzhund #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.allowsAssistanceDogs ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🐕</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.allowsAssistanceDogs ? 'text-green-700' : 'text-gray-400' }}">Assistenzhund erlaubt</p>
                            <p class="text-xs {{ restaurant.allowsAssistanceDogs ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.allowsAssistanceDogs ? 'Willkommen' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Helle Beleuchtung #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasBrightLighting ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💡</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasBrightLighting ? 'text-green-700' : 'text-gray-400' }}">Helle Beleuchtung</p>
                            <p class="text-xs {{ restaurant.hasBrightLighting ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasBrightLighting ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- HINWEISE (Accessibility Notes) --- #}
            {% if restaurant.accessibilityNotes is not empty %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Hinweise zur Barrierefreiheit</h2>
                    <div class="space-y-3">
                        {% for note in restaurant.accessibilityNotes %}
                            {% set parts = note|split(':') %}
                            {% set type = parts|first %}
                            {% set text = parts[1] %}
                            {% if type == 'ok' %}
                                <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg border border-green-100">
                                    <span class="text-green-500 text-lg font-bold">✓</span>
                                    <span class="text-sm text-green-800">{{ text }}</span>
                                </div>
                            {% elseif type == 'warn' %}
                                <div class="flex items-center gap-3 p-3 bg-yellow-50 rounded-lg border border-yellow-100">
                                    <span class="text-yellow-500 text-lg font-bold">!</span>
                                    <span class="text-sm text-yellow-800">{{ text }}</span>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-100">
                                    <span class="text-sm text-gray-600">{{ note }}</span>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# --- ERSTELLT AM --- #}
            <div class="text-center text-sm text-gray-400 mt-8">
                Eingetragen am {{ restaurant.createdAt|date('d.m.Y') }}
            </div>

        </div>
    </div>

{% endblock %}
