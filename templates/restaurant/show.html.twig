{% extends 'base.html.twig' %}

{% block title %}{{ restaurant.name }} – Endlech.lu{% endblock %}

{% block body %}

    <div class="min-h-screen bg-gray-50">

        {# --- HERO SECTION: Restaurant-Emoji und Name --- #}
        <div class="bg-linear-to-r from-cyan-600 to-purple-700 text-white py-16 shadow-md">
            <div class="container mx-auto px-4 text-center">
                <div class="text-7xl mb-4">{{ restaurant.emoji }}</div>
                <h1 class="text-3xl font-bold mb-2">{{ restaurant.name }}</h1>
                <p class="text-cyan-100 text-lg">{{ restaurant.city }} &bull; {{ restaurant.cuisine }}</p>
                <div class="flex items-center justify-center gap-3 mt-4 flex-wrap">
                    {% if restaurant.isOpen %}
                        <span class="inline-block bg-green-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geöffnet</span>
                    {% else %}
                        <span class="inline-block bg-red-500 text-white text-sm font-bold px-4 py-1.5 rounded-full shadow-sm">Geschlossen</span>
                    {% endif %}
                    {% include 'partials/_verified_badge.html.twig' with {restaurant: restaurant, size: 'lg'} %}
                </div>
            </div>
        </div>

        {# --- MAIN CONTENT --- #}
        <div class="container mx-auto px-4 py-8 max-w-3xl">

            {# Zurück-Link #}
            <a href="{{ path('app_restaurant_index') }}" class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-800 font-semibold mb-8 transition">
                ← Zurück zur Liste
            </a>

            {# --- VERIFIZIERUNGS-INFO-KARTE --- #}
            {% if restaurant.isVerified %}
            <div class="bg-cyan-50 rounded-xl border border-cyan-200 p-5 mb-6 flex items-start gap-4">
                <svg class="w-6 h-6 text-cyan-600 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/>
                </svg>
                <div>
                    <p class="text-sm font-bold text-cyan-800">Von Endlech.lu persönlich vor Ort geprüft</p>
                    <p class="text-xs text-cyan-600 mt-0.5">
                        Die Barrierefreiheitsangaben dieses Lokals wurden von unserem Team persönlich verifiziert.
                        {% if restaurant.verifiedAt is not null %}Geprüft am {{ restaurant.verifiedAt|date('d.m.Y') }}.{% endif %}
                    </p>
                </div>
            </div>
            {% endif %}

            {# --- BEWERTUNG --- #}
            {% if restaurant.rating is not null %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-3">Bewertung</h2>
                    <div class="flex items-center gap-3">
                        <div class="bg-cyan-50 text-cyan-700 px-4 py-2 rounded-lg text-2xl font-bold border border-cyan-100">{{ restaurant.rating }}</div>
                        <span class="text-gray-500 text-sm">von 10</span>
                    </div>
                </div>
            {% endif %}

            {# --- BARRIEREFREIHEIT (Accessibility Features) --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Barrierefreiheit</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                    {# Rollstuhlgerecht #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.isWheelchairAccessible ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">♿</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.isWheelchairAccessible ? 'text-green-700' : 'text-gray-400' }}">Rollstuhlgerecht</p>
                            <p class="text-xs {{ restaurant.isWheelchairAccessible ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.isWheelchairAccessible ? 'Stufenloser Zugang' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Barrierefreies WC #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasAccessibleToilet ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🚻</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasAccessibleToilet ? 'text-green-700' : 'text-gray-400' }}">Barrierefreies WC</p>
                            <p class="text-xs {{ restaurant.hasAccessibleToilet ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasAccessibleToilet ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Assistenzhund #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.allowsAssistanceDogs ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">🐕</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.allowsAssistanceDogs ? 'text-green-700' : 'text-gray-400' }}">Assistenzhund erlaubt</p>
                            <p class="text-xs {{ restaurant.allowsAssistanceDogs ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.allowsAssistanceDogs ? 'Willkommen' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                    {# Helle Beleuchtung #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.hasBrightLighting ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💡</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.hasBrightLighting ? 'text-green-700' : 'text-gray-400' }}">Helle Beleuchtung</p>
                            <p class="text-xs {{ restaurant.hasBrightLighting ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.hasBrightLighting ? 'Vorhanden' : 'Nicht verfügbar' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- ZAHLUNGSMETHODEN --- #}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">Zahlungsmethoden</h2>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                    {# Bargeld #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsCash ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💵</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsCash ? 'text-green-700' : 'text-gray-400' }}">Barzahlung</p>
                            <p class="text-xs {{ restaurant.acceptsCash ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsCash ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                    {# Karte #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsCard ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">💳</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsCard ? 'text-green-700' : 'text-gray-400' }}">Kreditkarte / EC</p>
                            <p class="text-xs {{ restaurant.acceptsCard ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsCard ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                    {# Payconiq #}
                    <div class="flex items-center gap-3 p-3 rounded-lg {{ restaurant.acceptsPayconiq ? 'bg-green-50 border border-green-100' : 'bg-gray-50 border border-gray-100' }}">
                        <span class="text-2xl">📱</span>
                        <div>
                            <p class="text-sm font-semibold {{ restaurant.acceptsPayconiq ? 'text-green-700' : 'text-gray-400' }}">Payconiq</p>
                            <p class="text-xs {{ restaurant.acceptsPayconiq ? 'text-green-600' : 'text-gray-400' }}">{{ restaurant.acceptsPayconiq ? 'Akzeptiert' : 'Nicht akzeptiert' }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# --- HINWEISE (Accessibility Notes) --- #}
            {% if restaurant.accessibilityNotes is not empty %}
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
                    <h2 class="text-lg font-bold text-gray-800 mb-4">Hinweise zur Barrierefreiheit</h2>
                    <div class="space-y-3">
                        {% for note in restaurant.accessibilityNotes %}
                            {% set parts = note|split(':') %}
                            {% set type = parts|first %}
                            {% set text = parts[1] %}
                            {% if type == 'ok' %}
                                <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg border border-green-100">
                                    <span class="text-green-500 text-lg font-bold">✓</span>
                                    <span class="text-sm text-green-800">{{ text }}</span>
                                </div>
                            {% elseif type == 'warn' %}
                                <div class="flex items-center gap-3 p-3 bg-yellow-50 rounded-lg border border-yellow-100">
                                    <span class="text-yellow-500 text-lg font-bold">!</span>
                                    <span class="text-sm text-yellow-800">{{ text }}</span>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-100">
                                    <span class="text-sm text-gray-600">{{ note }}</span>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# --- FOTOS (Galerie mit GLightbox) --- #}
            {% if restaurant.images is not empty %}
            <section class="mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-4">📷 Fotos</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                    {% for image in restaurant.images %}
                    <a href="/uploads/restaurants/{{ image.filename }}"
                       class="glightbox" data-gallery="restaurant-gallery" data-description="{{ image.altText }}">
                        <img src="/uploads/restaurants/{{ image.filename }}" alt="{{ image.altText }}"
                             class="w-full h-40 object-cover rounded-xl border border-gray-200 hover:opacity-90 transition">
                    </a>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {# --- ERSTELLT AM --- #}
            <div class="text-center text-sm text-gray-400 mt-8">
                Eingetragen am {{ restaurant.createdAt|date('d.m.Y') }}
            </div>

        </div>
    </div>

{% endblock %}
