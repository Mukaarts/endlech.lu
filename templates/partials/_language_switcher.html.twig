{# Language Switcher für öffentliche Seiten #}
{% set current_locale = app.request.locale %}
{% set current_route = app.request.attributes.get('_route') %}
{% set current_params = app.request.attributes.get('_route_params', {}) %}
{% set query_params = app.request.query.all() %}

{% set locales = {
    'lb': 'LB',
    'de': 'DE',
    'fr': 'FR',
    'en': 'EN'
} %}

<div class="relative" data-controller="language-switcher">
    <button
        type="button"
        class="flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-cyan-600 transition px-2 py-1 rounded-md hover:bg-gray-100"
        data-action="click->language-switcher#toggle"
        data-language-switcher-target="button"
        aria-expanded="false"
        aria-haspopup="true"
    >
        <span class="uppercase">{{ current_locale }}</span>
        <svg class="w-3.5 h-3.5 transition-transform" data-language-switcher-target="arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
    </button>

    <div
        class="absolute right-0 mt-1 w-28 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50 hidden"
        data-language-switcher-target="menu"
        data-action="click@window->language-switcher#close"
    >
        {% for locale, label in locales %}
            {% if locale != current_locale %}
                <a
                    href="{{ path(current_route, current_params|merge({'_locale': locale})|merge(query_params)) }}"
                    class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-cyan-600 transition"
                >
                    {{ label }}
                </a>
            {% else %}
                <span class="block px-4 py-2 text-sm font-semibold text-cyan-600">
                    {{ label }}
                </span>
            {% endif %}
        {% endfor %}
    </div>
</div>
