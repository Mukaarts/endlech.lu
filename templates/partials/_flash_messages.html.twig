{# Flash-Nachrichten (Erfolg, Fehler, Info) #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="{% if type == 'success' %}bg-green-50 border-green-400 text-green-800{% elseif type == 'error' %}bg-red-50 border-red-400 text-red-800{% else %}bg-blue-50 border-blue-400 text-blue-800{% endif %} border-l-4 px-4 py-3 rounded-r-lg mb-4" role="alert">
            <p class="text-sm font-medium">{{ message }}</p>
        </div>
    {% endfor %}
{% endfor %}
