{% extends 'base.html.twig' %}

{% block title %}{{ 'verify.title'|trans }}{% endblock %}

{% block body %}
<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 text-center">

            {# Icon #}
            <div class="mx-auto w-16 h-16 bg-cyan-50 rounded-full flex items-center justify-center mb-6">
                <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
            </div>

            <h1 class="text-2xl font-bold text-gray-900 mb-3">{{ 'verify.heading'|trans }}</h1>

            {% include 'partials/_flash_messages.html.twig' %}

            <p class="text-gray-500 text-sm mb-6 leading-relaxed">
                {{ 'verify.text'|trans }}
            </p>

            <div class="bg-gray-50 rounded-lg p-4 mb-6">
                <p class="text-xs text-gray-500">
                    {{ 'verify.link_validity'|trans|raw }}
                </p>
            </div>

            {% if app.user %}
                <a href="{{ path('app_verify_resend') }}" class="inline-block text-sm text-purple-600 font-semibold hover:text-purple-800 transition">
                    {{ 'verify.resend'|trans }}
                </a>
            {% endif %}

            <div class="mt-6">
                <a href="{{ path('app_home') }}" class="text-sm text-gray-500 hover:text-gray-700 transition">{{ 'verify.back_home'|trans }}</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
