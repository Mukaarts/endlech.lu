{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true,
        "sourceMap": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "types": ["webpack-env"]
    },
    "include": ["assets/**/*.ts"],
    "exclude": ["node_modules", "public"]
}
